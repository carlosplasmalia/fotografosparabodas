---
import { cities } from '../config/site';

const cityImages: Record<string, { full: string; sm: string }> = {
  madrid:          { full: '/images/photographers/plasmalia/foto2.webp',    sm: '/images/photographers/plasmalia/foto2-sm.webp' },
  malaga:          { full: '/images/cities/malaga.webp',          sm: '/images/cities/malaga-sm.webp' },
  zaragoza:        { full: '/images/cities/zaragoza.webp',        sm: '/images/cities/zaragoza-sm.webp' },
  murcia:          { full: '/images/cities/murcia.webp',          sm: '/images/cities/murcia-sm.webp' },
  bilbao:          { full: '/images/cities/bilbao.webp',          sm: '/images/cities/bilbao-sm.webp' },
  cordoba:         { full: '/images/cities/cordoba.webp',         sm: '/images/cities/cordoba-sm.webp' },
  alicante:        { full: '/images/cities/alicante.webp',        sm: '/images/cities/alicante-sm.webp' },
  valladolid:      { full: '/images/cities/valladolid.webp',      sm: '/images/cities/valladolid-sm.webp' },
  granada:         { full: '/images/cities/granada.webp',         sm: '/images/cities/granada-sm.webp' },
  'san-sebastian': { full: '/images/cities/san-sebastian.webp',   sm: '/images/cities/san-sebastian-sm.webp' },
  sevilla:         { full: '/images/cities/sevilla.webp',         sm: '/images/cities/sevilla-sm.webp' },
  valencia:        { full: '/images/cities/valencia.webp',        sm: '/images/cities/valencia-sm.webp' },
};
---

<section id="ciudades" class="py-24 bg-[#FAF7F2]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="section-eyebrow mb-4">Dónde trabajamos</p>
      <h2 class="section-title mb-4">Fotógrafos de boda<br/>en toda España</h2>
      <span class="gold-divider"></span>
      <p class="font-['Lato'] text-[#6B5E58] max-w-lg mx-auto mt-6 leading-relaxed">
        Selecciona tu ciudad y encuentra el fotógrafo que mejor conecte con vuestra historia.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-4">
      {cities.map(city => (
        <a
          href={`/${city.slug}/`}
          class="group relative aspect-[4/3] overflow-hidden rounded-sm bg-[#E8DDD3]"
        >
          <img
            src={cityImages[city.slug]?.full ?? '/images/hero-boda.webp'}
            srcset={cityImages[city.slug] ? `${cityImages[city.slug].sm} 200w, ${cityImages[city.slug].full} 380w` : undefined}
            sizes="(max-width: 640px) calc(50vw - 28px), 380px"
            alt={`Fotógrafo de bodas en ${city.name}`}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            width="380"
            height="285"
            loading="lazy"
            decoding="async"
          />
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
          <!-- Text -->
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <p class="font-['Cormorant_Garamond'] text-xl font-semibold text-white leading-tight">
              {city.name}
            </p>
          </div>
          <!-- Gold border on hover -->
          <div class="absolute inset-0 border border-[#8B6A3A]/0 group-hover:border-[#8B6A3A]/60 transition-all duration-300 pointer-events-none rounded-sm"></div>
        </a>
      ))}
    </div>

    <p class="text-center font-['Lato'] text-sm text-[#6B5E58] mt-8">
      ¿Tu ciudad no aparece?
      <a href="/#contacto" class="text-[#8B6A3A] underline ml-1">Consúltanos</a>
    </p>
  </div>
</section>
