---
import { site } from '../config/site';

interface Props {
  city: string;
}

const { city } = Astro.props;

const waText = encodeURIComponent(
  `Hola, buscamos fotógrafo de bodas en ${city}. ¿Podéis ayudarnos a encontrar el ideal para nuestra boda?`
);
---

<section id="fotografos" class="py-20 bg-[#FAF7F2]">
  <div class="max-w-4xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-14">
      <p class="section-eyebrow mb-4">Nuestro servicio en {city}</p>
      <h2 class="section-title">Encontramos al fotógrafo ideal<br/>para vuestra boda</h2>
      <span class="gold-divider"></span>
      <p class="font-['Lato'] text-[#6B5E58] max-w-lg mx-auto mt-6 leading-relaxed text-sm">
        Trabajamos con una red de fotógrafos verificados en toda España. Describidnos vuestra boda y os presentamos al profesional que mejor encaja con vuestro estilo, venue y presupuesto.
      </p>
    </div>

    <!-- How it works: 3 pasos -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14">
      {[
        {
          step: '01',
          title: 'Nos contáis vuestra boda',
          body: 'Fecha, ciudad, número de invitados y qué estilo os gusta. Por WhatsApp, en cinco minutos.',
        },
        {
          step: '02',
          title: 'Os presentamos al fotógrafo',
          body: 'En menos de 24 horas os presentamos el fotógrafo de nuestra red que mejor encaja con vuestro perfil.',
        },
        {
          step: '03',
          title: 'Vosotros decidís, sin presión',
          body: 'Veis el portfolio, hacéis preguntas y decidís. Gratis y sin compromiso en todo el proceso.',
        },
      ].map(item => (
        <div class="bg-white border border-[#E8DDD3] rounded-sm p-7 relative overflow-hidden">
          <span class="absolute top-4 right-5 font-['Cormorant_Garamond'] text-5xl font-semibold text-[#F2E8D5] leading-none select-none">
            {item.step}
          </span>
          <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-3 pr-8 relative">
            {item.title}
          </h3>
          <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed relative">
            {item.body}
          </p>
        </div>
      ))}
    </div>

    <!-- CTA principal -->
    <div class="bg-[#1C1814] rounded-sm p-10 text-center mb-8">
      <p class="font-['Cormorant_Garamond'] text-3xl font-semibold text-white mb-3">
        ¿Boda en {city}?
      </p>
      <p class="font-['Lato'] text-sm text-[#6B5E58] max-w-md mx-auto mb-8 leading-relaxed">
        Cuéntadnos vuestra fecha y cómo imaginais el reportaje. Os respondemos antes de 24 horas con las mejores opciones de nuestra red.
      </p>
      <a
        href={`https://wa.me/${site.whatsapp}?text=${waText}`}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-gold text-base px-10 py-4 inline-flex items-center gap-3"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Consultar fotógrafos en {city}
      </a>
      <p class="font-['Lato'] text-xs text-[#6B5E58] mt-4">Gratis · Sin compromiso · Respuesta en 24 horas</p>
    </div>

    <!-- Trust signals -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {[
        { n: '< 24h', label: 'Tiempo de respuesta' },
        { n: '100%', label: 'Gratuito para novios' },
        { n: '+9',   label: 'Ciudades en España' },
        { n: 'Curado', label: 'Selección manual de cada fotógrafo' },
      ].map(s => (
        <div class="bg-white border border-[#E8DDD3] rounded-sm p-4 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A]">{s.n}</p>
          <p class="font-['Lato'] text-[10px] text-[#6B5E58] mt-1 leading-snug">{s.label}</p>
        </div>
      ))}
    </div>

    <!-- CTA fotógrafos -->
    <div class="mt-8 border border-dashed border-[#E8DDD3] rounded-sm p-6 text-center">
      <p class="font-['Lato'] text-sm text-[#6B5E58] mb-3">
        ¿Eres fotógrafo de bodas en {city}? Trabajamos con los mejores profesionales de cada ciudad.
      </p>
      <a href="/unete/" class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] hover:underline">
        Únete a nuestra red →
      </a>
    </div>

  </div>
</section>
