---
const steps = [
  {
    num: '01',
    title: 'Contadnos vuestra boda',
    body: 'Ciudad, fecha, venue y el estilo que os imagináis. Por WhatsApp o formulario, en menos de dos minutos. Es gratis y sin compromiso.',
  },
  {
    num: '02',
    title: 'Os seleccionamos el ideal',
    body: 'En menos de 24 horas os presentamos 2-3 fotógrafos de nuestra red que encajan con vuestro estilo y presupuesto. Siempre con disponibilidad confirmada.',
  },
  {
    num: '03',
    title: 'Cerráis y disfrutáis',
    body: 'Conectáis directamente con el fotógrafo, veis su portfolio real y reserváis. Nosotros seguimos disponibles si necesitáis cualquier gestión.',
  },
];
---

<section id="como-funciona" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="section-eyebrow mb-4">El proceso</p>
      <h2 class="section-title">Un servicio de selección<br/>personalizado y gratuito</h2>
      <span class="gold-divider"></span>
      <p class="font-['Lato'] text-[#6B5E58] mt-6 max-w-xl mx-auto leading-relaxed">
        No somos un directorio. Somos el intermediario que os ahorra semanas de investigación y os evita contratar al fotógrafo equivocado.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative">
      <!-- Connector line (desktop) -->
      <div class="hidden md:block absolute top-8 left-1/6 right-1/6 h-px bg-[#E8DDD3]" style="left:16.66%;right:16.66%"></div>

      {steps.map(step => (
        <div class="flex flex-col items-center text-center relative">
          <div class="w-16 h-16 rounded-full bg-[#FAF7F2] border border-[#B89060] flex items-center justify-center mb-6 z-10">
            <span class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#B89060]">
              {step.num}
            </span>
          </div>
          <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mb-3">
            {step.title}
          </h3>
          <p class="font-['Lato'] text-[#6B5E58] text-sm leading-relaxed max-w-xs">
            {step.body}
          </p>
        </div>
      ))}
    </div>

    <div class="text-center mt-14">
      <a href="https://wa.me/34625677487?text=Hola%2C%20busco%20fotógrafo%20de%20bodas.%20¿Podéis%20ayudarme%3F" target="_blank" rel="noopener noreferrer" class="btn-gold">
        Consultar ahora — es gratis
      </a>
    </div>
  </div>
</section>
