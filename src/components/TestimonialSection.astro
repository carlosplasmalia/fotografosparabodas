---
const testimonials = [
  {
    quote: 'Encontramos a nuestro fotógrafo en menos de una hora. Su trabajo capturó exactamente la emoción que buscábamos. Las fotos son nuestro tesoro más preciado de ese día.',
    name: 'Laura & Marcos',
    city: 'Málaga',
    year: '2025',
  },
  {
    quote: 'Nos daba miedo contratar sin referencias, pero el directorio nos dio toda la información que necesitábamos. Terminamos con un fotógrafo increíble y dentro de presupuesto.',
    name: 'Sofía & Javier',
    city: 'Zaragoza',
    year: '2025',
  },
  {
    quote: 'La variedad de estilos que encontramos fue brutal. Elegimos un estilo documental que ni sabíamos que existía y el resultado fue espectacular. Totalmente recomendable.',
    name: 'Carmen & David',
    city: 'Murcia',
    year: '2026',
  },
];
---

<section class="py-24 bg-[#F2E8D5]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="section-eyebrow mb-4">Testimonios</p>
      <h2 class="section-title">Lo que dicen<br/>las parejas</h2>
      <span class="gold-divider"></span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(t => (
        <div class="bg-white p-8 rounded-sm shadow-sm relative">
          <!-- Quote mark -->
          <div class="font-['Cormorant_Garamond'] text-7xl text-[#8B6A3A]/20 absolute top-4 left-6 leading-none select-none">
            "
          </div>
          <p class="font-['Lato'] text-[#1C1814] text-sm leading-relaxed relative z-10 pt-4">
            {t.quote}
          </p>
          <div class="mt-6 pt-6 border-t border-[#F2E8D5] flex items-center justify-between">
            <div>
              <p class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814]">{t.name}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58]">{t.city}, {t.year}</p>
            </div>
            <!-- Stars -->
            <div class="flex gap-0.5">
              {Array(5).fill(0).map(() => (
                <span class="text-[#8B6A3A] text-sm">★</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
