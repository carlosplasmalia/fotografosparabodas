---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = posts.filter(p => p.data.featured);
const rest = posts.filter(p => !p.data.featured);

const categorias = [...new Set(posts.map(p => p.data.categoria).filter(Boolean))];
---

<BaseLayout
  title="Guías de fotografía de bodas — Consejos para novios 2026"
  description="Guías prácticas sobre fotografía de bodas: precios, estilos, cómo elegir fotógrafo y qué incluye un reportaje. Todo lo que necesitas saber antes de decidir."
  canonical="https://fotografosparabodas.es/blog/"
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2] min-h-screen">

    <!-- Hero del blog -->
    <section class="bg-[#1C1814] py-20">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <p class="section-eyebrow text-[#B89060] mb-4">Guías para novios</p>
        <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-semibold text-white leading-tight mb-6">
          Todo lo que necesitas saber<br/>antes de elegir fotógrafo
        </h1>
        <p class="font-['Lato'] text-[#9A8880] text-lg max-w-xl mx-auto">
          Precios reales, estilos explicados y las preguntas que ningún blog de bodas te cuenta.
        </p>
      </div>
    </section>

    <div class="max-w-5xl mx-auto px-6 py-16">

      <!-- Featured posts -->
      {featured.length > 0 && (
        <section class="mb-16">
          <p class="section-eyebrow mb-8">Guías esenciales</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {featured.map(post => (
              <a
                href={`/blog/${post.id}/`}
                class="group bg-white border border-[#E8DDD3] rounded-sm overflow-hidden hover:shadow-lg transition-shadow"
              >
                {post.data.imagen && (
                  <div class="h-48 overflow-hidden bg-[#E8DDD3]">
                    <img
                      src={post.data.imagen}
                      alt={post.data.imagenAlt ?? post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="p-6">
                  {post.data.categoria && (
                    <span class="font-['Lato'] text-[10px] font-bold tracking-widest uppercase text-[#B89060]">
                      {post.data.categoria}
                    </span>
                  )}
                  <h2 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mt-2 mb-3 group-hover:text-[#B89060] transition-colors leading-tight">
                    {post.data.title}
                  </h2>
                  <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed line-clamp-2">
                    {post.data.description}
                  </p>
                  <span class="inline-block mt-4 font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060]">
                    Leer guía →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Rest of posts -->
      {rest.length > 0 && (
        <section>
          <p class="section-eyebrow mb-8">Más guías</p>
          <div class="space-y-4">
            {rest.map(post => (
              <a
                href={`/blog/${post.id}/`}
                class="group flex gap-6 bg-white border border-[#E8DDD3] rounded-sm p-5 hover:shadow-md transition-shadow items-center"
              >
                {post.data.imagen && (
                  <div class="w-24 h-20 shrink-0 overflow-hidden rounded-sm bg-[#E8DDD3]">
                    <img
                      src={post.data.imagen}
                      alt={post.data.imagenAlt ?? post.data.title}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  {post.data.categoria && (
                    <span class="font-['Lato'] text-[10px] font-bold tracking-widest uppercase text-[#B89060]">
                      {post.data.categoria}
                    </span>
                  )}
                  <h2 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mt-1 group-hover:text-[#B89060] transition-colors leading-tight">
                    {post.data.title}
                  </h2>
                  <p class="font-['Lato'] text-sm text-[#9A8880] mt-1 line-clamp-1">
                    {post.data.description}
                  </p>
                </div>
                <span class="shrink-0 text-[#B89060] font-['Lato'] text-lg">→</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- CTA directorio -->
      <div class="mt-16 bg-[#1C1814] rounded-sm p-10 text-center">
        <p class="section-eyebrow text-[#B89060] mb-4">¿Listos para elegir?</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-white mb-4">
          Explorad el directorio de fotógrafos
        </h2>
        <p class="font-['Lato'] text-[#9A8880] max-w-md mx-auto mb-8 text-sm leading-relaxed">
          Perfiles verificados, portfolios reales y consulta de disponibilidad directa. Sin intermediarios.
        </p>
        <a href="/#ciudades" class="btn-gold">Ver fotógrafos disponibles</a>
      </div>
    </div>
  </main>
  <SiteFooter />
  <WhatsAppFloat />
</BaseLayout>
