---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import PhotographerProfile from '../../components/PhotographerProfile.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const city = 'Córdoba';
const slug = 'cordoba';
const avgPrice = '1.200€ – 2.000€';

const photographers = [
  {
    name: 'Carmen Espinosa',
    city: 'Córdoba',
    zone: 'Córdoba · Sevilla · Jaén',
    style: 'Documental andaluz',
    styleDesc: 'Emoción pura en bodas con carácter andaluz y luz del sur',
    price: 'desde 1.400€',
    bio: 'Carmen Espinosa lleva más de 9 años fotografiando bodas en Córdoba y toda Andalucía. Su trabajo está profundamente influido por la arquitectura nazarí y el carácter festivo de las bodas del sur. Experta en trabajar la luz dorada del mediodía cordobés y en bodas de patio andaluz.',
    avatar: '/images/cities/cordoba.jpg',
    portfolio: [
      { src: '/images/portfolio/malaga-1.jpg', alt: 'Boda en Córdoba — Carmen Espinosa' },
      { src: '/images/portfolio/malaga-4.jpg', alt: 'Fotografía boda patio andaluz — Carmen Espinosa' },
      { src: '/images/cities/cordoba.jpg',     alt: 'Bodas Córdoba — Carmen Espinosa' },
    ],
    badge: 'Verificado',
    yearsExp: 9,
    awards: ['Fearless Photographers Associate', 'Top Andalucía Weddings 2023'],
    photoCredit: 'Carmen Espinosa',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Mejores fotógrafos de bodas en ${city}`,
  "description": `Directorio de los mejores fotógrafos de bodas en ${city} y Andalucía.`,
  "url": `https://${site.domain}/${slug}/`,
  "numberOfItems": photographers.length,
  "itemListElement": photographers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.name,
      "description": p.bio,
      "areaServed": { "@type": "City", "name": city },
      "priceRange": p.price,
      "knowsAbout": "Fotografía de bodas",
    }
  })),
};
---

<BaseLayout
  title="Fotógrafos de Bodas en Córdoba — Directorio verificado 2026"
  description="Los mejores fotógrafos de bodas en Córdoba. Bodas en patios andaluces, haciendas y la Mezquita. Perfiles verificados. Precio medio: 1.200€ – 2.000€."
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafos de Bodas\nen Córdoba`}
      subtitle="Especialistas en bodas en patios andaluces, haciendas y los escenarios únicos de Córdoba y su provincia."
      ctaText="Ver fotógrafos"
      ctaHref="#fotografos"
      imageSrc="/images/cities/cordoba.jpg"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Córdoba y provincia</p>
            <h2 class="section-title mb-6">Patios, haciendas<br/>y luz andaluza</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Córdoba tiene una belleza arquitectónica difícil de superar para una boda: los patios con geranios, los arcos de la Mezquita-Catedral o las haciendas del Guadalquivir. El problema es que esa misma belleza exige fotógrafos que sepan manejarse en interiores oscuros y exteriores con luz muy intensa.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              Los fotógrafos de nuestro directorio conocen estos espacios y saben cómo resolver la luz sin perder la esencia del lugar. Eso marca la diferencia entre una foto bonita y una foto memorable.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Precio medio', value: avgPrice },
                { label: 'Fotógrafos verificados', value: `${photographers.length} activo` },
                { label: 'Temporada alta', value: 'Abril – Junio, Septiembre – Octubre' },
                { label: 'Zonas populares', value: 'Patios, haciendas, El Brillante, Sierra Morena' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="fotografos" class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Directorio exclusivo</p>
          <h2 class="section-title">Fotógrafo de boda<br/>de referencia en Córdoba</h2>
          <span class="gold-divider"></span>
        </div>

        <div class="space-y-8">
          {photographers.map((p, i) => <PhotographerProfile photographer={p} featured={i === 0} />)}
        </div>

        <div class="mt-8 border-2 border-dashed border-[#E8DDD3] rounded-sm p-10 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#6B5E58] mb-3">Plaza disponible en Córdoba</p>
          <p class="font-['Lato'] text-sm text-[#9A8880] max-w-sm mx-auto mb-6 leading-relaxed">
            Seleccionamos un segundo fotógrafo para cubrir Córdoba y alrededores. ¿Te dedicas a la fotografía de bodas en la provincia?
          </p>
          <a href="/unete/" class="btn-outline text-sm px-6 py-3">Solicitar plaza →</a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cuánto cuesta un fotógrafo de bodas en Córdoba?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            En Córdoba, un fotógrafo de bodas cuesta entre <strong class="text-[#1C1814]">1.200€ y 2.000€</strong>. El precio es ligeramente inferior al de Sevilla o Málaga, aunque los mejores fotógrafos de la ciudad trabajan con tarifas similares a las del resto de Andalucía occidental.
          </p>
          <p>
            Las bodas de primavera en Córdoba (especialmente durante el Festival de los Patios en mayo) tienen una demanda muy alta. Si queréis casaros en mayo o junio, contactad con mínimo 12 meses de antelación.
          </p>
          <p>
            Los extras más habituales son la sesión preboda en la Judería o el Alcázar, y el álbum impreso artesanal para recordar cada detalle.
          </p>
        </div>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También en Andalucía</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-8">Más ciudades</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Granada', slug: 'granada' },
            { name: 'Málaga', slug: 'malaga' },
            { name: 'Madrid', slug: 'madrid' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">
              Fotógrafos en {c.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
