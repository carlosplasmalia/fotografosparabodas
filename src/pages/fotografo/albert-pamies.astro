---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const p = {
  name: 'Albert Pamies',
  slug: 'albert-pamies',
  city: 'Málaga',
  citySlug: 'malaga',
  zone: 'Málaga · Marbella · Costa del Sol · España y Europa',
  style: 'Documental emocional',
  tagline: 'Naturalidad, emoción y elegancia en cada fotograma.',
  yearsExp: 12,
  instagram: 'albertpamies',
  web: 'https://albertpamies.com',
  avatar: '/images/photographers/albert/avatar.jpg',
  coverImage: '/images/photographers/albert/foto1.jpg',
  portfolio: [
    { src: '/images/photographers/albert/foto1.jpg', alt: 'Boda en Málaga — Albert Pamies fotógrafo' },
    { src: '/images/photographers/albert/foto2.jpg', alt: 'Pareja en Costa del Sol — Albert Pamies' },
    { src: '/images/photographers/albert/foto3.jpg', alt: 'Momento íntimo de boda Málaga — Albert Pamies' },
    { src: '/images/photographers/albert/avatar.jpg', alt: 'Detalle boda Marbella — Albert Pamies' },
    { src: '/images/cities/malaga.jpg',               alt: 'Boda al atardecer Costa del Sol — Albert Pamies' },
    { src: '/images/portfolio/malaga-5.jpg',          alt: 'Ceremonia boda Málaga — Albert Pamies' },
    { src: '/images/portfolio/malaga-6.jpg',          alt: 'Invitados boda Nerja — Albert Pamies' },
    { src: '/images/portfolio/malaga-3.jpg',          alt: 'Sesión preboda Ronda — Albert Pamies' },
  ],
  awards: ['Fearless Photographers USA', 'MyWed #1 Mundial 2019', 'Inspiration Photographers Brazil'],
  services: [
    { title: 'Cobertura del día completo', desc: 'Desde los preparativos hasta el cierre del baile. Sin límite de horas.' },
    { title: 'Sesión preboda', desc: 'Una sesión previa para que lleguéis relajados al gran día con la cámara ya como una amiga.' },
    { title: 'Galería privada online', desc: 'Entre 500 y 800 imágenes editadas en alta resolución, entregadas en 6 semanas.' },
    { title: 'Bodas de destino', desc: 'Viaja a toda España y Europa. Más de 50 bodas de destino documentadas.' },
  ],
};

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://${site.domain}/fotografo/${p.slug}/`,
  "name": p.name,
  "description": "Fotógrafo de bodas en Málaga y Costa del Sol. Estilo documental emocional. Premiado por Fearless Photographers y MyWed #1 Mundial 2019.",
  "url": `https://${site.domain}/fotografo/${p.slug}/`,
  "image": `https://${site.domain}${p.avatar}`,
  "areaServed": [
    { "@type": "City", "name": "Málaga" },
    { "@type": "City", "name": "Marbella" },
    { "@type": "AdministrativeArea", "name": "Andalucía" },
  ],
  "knowsAbout": "Fotografía de bodas documental",
  "award": p.awards,
  "sameAs": [`https://instagram.com/${p.instagram}`, p.web],
};
---

<BaseLayout
  title="Albert Pamies — Fotógrafo de Bodas en Málaga · Costa del Sol"
  description="Albert Pamies, fotógrafo de bodas en Málaga con 12 años de experiencia. Estilo documental, premiado internacionalmente. Fearless Photographers USA · MyWed #1 Mundial. Consulta disponibilidad."
  canonical={`https://${site.domain}/fotografo/${p.slug}/`}
  schema={schemaOrg}
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2]">

    <!-- COVER: full-bleed editorial -->
    <section class="relative h-[75vh] min-h-[520px] overflow-hidden bg-[#1C1814]">
      <img
        src={p.coverImage}
        alt="Albert Pamies fotógrafo de bodas en Málaga"
        class="w-full h-full object-cover opacity-75"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#1C1814] via-[#1C1814]/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 pb-14">
        <div class="flex items-end gap-6">
          <img
            src={p.avatar}
            alt="Albert Pamies"
            class="w-24 h-24 rounded-full object-cover border-2 border-[#B89060] shrink-0 shadow-xl"
            loading="eager"
          />
          <div>
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] mb-1">
              Fotógrafo de bodas verificado · Málaga
            </p>
            <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-semibold text-white leading-none mb-2">
              Albert Pamies
            </h1>
            <p class="font-['Lato'] text-white/70 text-base italic">
              "{p.tagline}"
            </p>
            <div class="flex flex-wrap gap-2 mt-3">
              {p.awards.map(a => (
                <span class="font-['Lato'] text-[10px] px-2 py-1 bg-[#B89060]/20 border border-[#B89060]/40 text-[#F2E8D5] rounded-sm">
                  🏆 {a}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- META BAR -->
    <div class="bg-[#1C1814] border-b border-[#2E2520]">
      <div class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Estilo</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.style}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Zona</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.zone}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Experiencia</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.yearsExp} años</span>
        </div>
        <div class="ml-auto">
          <a
            href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20el%20fotógrafo%20${encodeURIComponent(p.name)}.%20¿Podéis%20consultarme%20disponibilidad%3F`}
            target="_blank" rel="noopener noreferrer"
            class="btn-gold text-sm py-2.5 px-5"
          >
            Consultar disponibilidad
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 space-y-20">

      <!-- PORTFOLIO GRID: 8 fotos, grid editorial -->
      <section>
        <div class="flex items-baseline justify-between mb-8">
          <div>
            <p class="section-eyebrow mb-2">Portfolio</p>
            <h2 class="section-title">Bodas en Málaga y Costa del Sol</h2>
          </div>
          <a href={`https://instagram.com/${p.instagram}`} target="_blank" rel="noopener noreferrer nofollow"
            class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] hover:underline">
            Ver más en IG →
          </a>
        </div>

        <!-- Grid principal: 2 columnas, filas mixtas -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          <!-- Imagen grande: ocupa 2 cols + 2 filas -->
          <div class="col-span-2 row-span-2 overflow-hidden rounded-sm bg-[#E8DDD3] aspect-[4/3]">
            <img src={p.portfolio[0].src} alt={p.portfolio[0].alt}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              loading="eager" decoding="async" />
          </div>
          <!-- 2 imágenes cuadradas a la derecha -->
          {p.portfolio.slice(1, 3).map(img => (
            <div class="overflow-hidden rounded-sm bg-[#E8DDD3] aspect-square">
              <img src={img.src} alt={img.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading="lazy" decoding="async" />
            </div>
          ))}
          <!-- 4 imágenes cuadradas en fila inferior -->
          {p.portfolio.slice(3, 7).map(img => (
            <div class="overflow-hidden rounded-sm bg-[#E8DDD3] aspect-square">
              <img src={img.src} alt={img.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading="lazy" decoding="async" />
            </div>
          ))}
          <!-- Imagen panorámica final: ocupa todo el ancho -->
          <div class="col-span-2 md:col-span-4 overflow-hidden rounded-sm bg-[#E8DDD3] aspect-[16/5]">
            <img src={p.portfolio[7].src} alt={p.portfolio[7].alt}
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              loading="lazy" decoding="async" />
          </div>
        </div>
        <p class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">
          Fotos: <a href={p.web} target="_blank" rel="noopener noreferrer nofollow" class="hover:underline">albertpamies.com</a>
        </p>
      </section>

      <!-- TEXTO SEO: artículo editorial -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="md:col-span-2 space-y-6">
          <div>
            <p class="section-eyebrow mb-4">Sobre Albert Pamies</p>
            <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6 leading-snug">
              Doce años fotografiando<br/>lo que no se puede repetir
            </h2>
          </div>

          <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
            <p>
              Albert Pamies lleva más de doce años fotografiando bodas en Málaga y la Costa del Sol. En ese tiempo ha acumulado un palmarés internacional poco habitual: premiado por Fearless Photographers en Estados Unidos, clasificado número uno mundial por MyWed en 2019, reconocido por Inspiration Photographers en Brasil. Podría llenar esta página con galardones. Pero lo que de verdad distingue su trabajo no son los premios, sino algo que se nota en cuanto ves una boda completa suya: la capacidad de estar exactamente donde tiene que estar en el momento exacto en que algo importante ocurre.
            </p>
            <p>
              Su estilo es documental en la médula. No pide poses, no detiene la ceremonia para reencuadrar, no organiza grupos de invitados junto a la piscina. Se funde entre la gente y fotografía lo que pasa, con la confianza de quien sabe que lo que pasa siempre vale la pena si se mira desde el ángulo correcto. El resultado son imágenes que no parecen fotos de boda en el sentido convencional. Parecen fotogramas de una película que alguien rodó mientras vivía ese día con vosotros.
            </p>

            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] pt-2">
              La luz mediterránea como ventaja real
            </h3>
            <p>
              Almayate, el pueblo donde nació Albert, está a media hora de Málaga capital. Creció con la luz mediterránea, la conoce en cada estación y a cada hora del día. Eso no es un dato de marketing: es una ventaja operativa concreta cuando tienes que fotografiar una boda en una finca de Ronda con el sol de agosto a plomo, o en los jardines de Marbella a las seis de la tarde de octubre, con esa luz dorada que dura veinte minutos y luego desaparece.
            </p>
            <p>
              La provincia de Málaga tiene una diversidad de escenarios que pocos territorios españoles igualan. Las playas de Nerja, los cortijos del Guadalhorce, los palacios del centro histórico, las fincas de la Axarquía, las villas de la Costa del Sol. Albert ha fotografiado bodas en todos esos entornos. Sabe qué hora tiene cada lugar, dónde hay sombra en julio y dónde llega la última luz en enero. Ese conocimiento geográfico y lumínico se traduce directamente en fotos mejores.
            </p>

            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] pt-2">
              Cómo trabaja Albert el día de vuestra boda
            </h3>
            <p>
              La mayoría de los fotógrafos de boda llegan con un plan. Albert llega con una actitud. Su objetivo, si se puede llamar así, es estar siempre en el lugar correcto sin que nadie le vea llegar. Eso requiere una lectura constante del espacio y de las personas que hay en él.
            </p>
            <p>
              Durante los preparativos trabaja en paralelo con los novios, siguiendo el ritmo natural de la mañana sin imponer el suyo. En la ceremonia se mueve con discreción por los márgenes, buscando los ángulos que capturan la expresión de quien escucha tanto como la de quien habla. En el cóctel desaparece entre los invitados. En el baile está en medio de todo.
            </p>
            <p>
              La sesión de pareja, que suele hacerse durante el cóctel o justo antes del atardecer, es el único momento en que trabaja de forma más dirigida. No es una sesión de poses, pero sí de intención: busca un lugar con buena luz, os da espacio y espera a que ocurra algo real. Una mirada, una carcajada, un silencio. Lo que sea, siempre que sea verdad.
            </p>
            <p>
              El resultado de ese proceso es un reportaje con dos cualidades raramente juntas: la autenticidad del documental y la elegancia de la fotografía de autor. No son fotos de boda estándar. Son fotos que dentro de veinte años seguirán siendo exactamente buenas.
            </p>

            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] pt-2">
              Preboda, entrega y lo que necesitáis saber antes de reservar
            </h3>
            <p>
              Un reportaje completo con Albert cubre el día íntegro, desde los preparativos hasta el cierre del baile. Las fotos se entregan en galería privada online, en alta resolución, sin marca de agua, con derechos de uso personal completos. El número de imágenes varía según la boda, pero la media está entre 500 y 800 fotografías seleccionadas con criterio, no entregadas en bloque.
            </p>
            <p>
              La sesión preboda es optativa pero muy recomendable. Una hora o dos antes de la boda, en una localización elegida por vosotros, sin agenda ni invitados. Sirve para que el fotógrafo os conozca en un contexto relajado, para perder el miedo a la cámara y para llegar al gran día con una relación de confianza ya establecida. La diferencia en las fotos es visible.
            </p>
            <p>
              Albert viaja a toda España y Europa. Para fechas en temporada alta en la Costa del Sol (mayo a octubre), la lista de espera puede superar los doce meses. Si tenéis fecha, consultad disponibilidad cuanto antes.
            </p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
          <!-- Awards -->
          <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">Reconocimientos</p>
            <ul class="space-y-3">
              {p.awards.map(a => (
                <li class="flex items-start gap-3">
                  <span class="text-[#B89060] mt-0.5">🏆</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814] leading-snug">{a}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Stats -->
          <div class="bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">En cifras</p>
            <ul class="space-y-3">
              {[
                { n: '+12', label: 'años fotografiando bodas' },
                { n: '+200', label: 'bodas documentadas' },
                { n: '+50', label: 'bodas de destino' },
                { n: '500-800', label: 'fotos editadas entregadas' },
              ].map(s => (
                <li class="flex items-baseline justify-between gap-2">
                  <span class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#B89060]">{s.n}</span>
                  <span class="font-['Lato'] text-xs text-[#6B5E58] text-right">{s.label}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- CTA card -->
          <div class="bg-[#1C1814] rounded-sm p-6 text-white">
            <p class="font-['Cormorant_Garamond'] text-2xl font-semibold mb-3">¿Queréis trabajar con Albert?</p>
            <p class="font-['Lato'] text-sm text-[#9A8880] leading-relaxed mb-5">
              Consultadnos fecha y ciudad. Confirmamos disponibilidad en menos de 24 horas.
            </p>
            <a
              href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Albert%20Pamies%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
              target="_blank" rel="noopener noreferrer"
              class="btn-gold w-full text-sm py-3 text-center block"
            >
              Consultar por WhatsApp →
            </a>
            <p class="font-['Lato'] text-[10px] text-[#6B5E58] text-center mt-3">Sin compromiso · 24h</p>
          </div>
        </div>
      </section>

      <!-- SERVICIOS -->
      <section>
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Qué incluye</p>
          <h2 class="section-title">Servicios y paquetes</h2>
          <span class="gold-divider"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {p.services.map(s => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-2">{s.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA FINAL -->
      <section class="bg-[#F2E8D5] rounded-sm p-10 text-center">
        <p class="section-eyebrow mb-4">¿Conectamos?</p>
        <h2 class="section-title mb-4">Consultad disponibilidad<br/>sin compromiso</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 max-w-md mx-auto leading-relaxed text-sm">
          Contadnos vuestra fecha y dónde es la boda. Confirmamos si Albert está disponible ese día y os enviamos toda la información.
        </p>
        <a
          href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Albert%20Pamies%20para%20mi%20boda%20en%20Málaga.%20¿Podéis%20consultarme%20disponibilidad%3F`}
          target="_blank" rel="noopener noreferrer"
          class="btn-gold text-base px-10 py-4 inline-flex items-center gap-3"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Consultar por WhatsApp
        </a>
        <p class="font-['Lato'] text-xs text-[#9A8880] mt-4">
          O vuelve al directorio de <a href="/malaga/" class="text-[#B89060] hover:underline">fotógrafos de bodas en Málaga</a>
        </p>
      </section>

    </div>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={p.city} />
</BaseLayout>
