---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const p = {
  name: 'Albert Pamies',
  slug: 'albert-pamies',
  city: 'Málaga',
  citySlug: 'malaga',
  zone: 'Málaga · Marbella · Costa del Sol · España y Europa',
  style: 'Documental emocional',
  tagline: 'Naturalidad, emoción y elegancia en cada fotograma.',
  yearsExp: 12,
  instagram: 'albertpamies',
  web: 'https://albertpamies.com',
  avatar: '/images/photographers/albert/avatar.webp',
  coverImage: '/images/photographers/albert/ap06.webp',
  awards: ['Fearless Photographers USA', 'MyWed #1 Mundial 2019', 'Inspiration Photographers Brazil'],
};

const faq = [
  {
    q: '¿Albert Pamies viaja fuera de Málaga?',
    a: 'Sí. Albert cubre bodas en toda España y Europa. Más de 50 bodas de destino en su trayectoria. Para bodas fuera de la Costa del Sol, consultad el desplazamiento en el presupuesto.',
  },
  {
    q: '¿Cuánto tiempo antes hay que reservar a Albert Pamies?',
    a: 'Para bodas en temporada alta en la Costa del Sol (mayo a octubre), la agenda se llena con 12-18 meses de antelación. Si tenéis fecha fija, consultad disponibilidad cuanto antes.',
  },
  {
    q: '¿Cuántas fotos entrega Albert y cuándo?',
    a: 'El reportaje completo incluye entre 500 y 800 fotografías seleccionadas y editadas en alta resolución, entregadas en galería privada online en aproximadamente 6 semanas tras la boda.',
  },
  {
    q: '¿Qué es la sesión preboda y merece la pena?',
    a: 'Es una sesión de una o dos horas antes de la boda en una localización elegida por vosotros. Sirve para conocer al fotógrafo en un contexto relajado y perder el miedo a la cámara. La diferencia en la naturalidad de las fotos del día es muy visible.',
  },
  {
    q: '¿Trabaja Albert Pamies con segundo fotógrafo?',
    a: 'Sí, en bodas grandes o cuando se solicita expresamente. La cobertura con segundo fotógrafo permite documentar en paralelo los preparativos de ambas partes y capturar más ángulos durante la ceremonia.',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Person"],
  "@id": `https://${site.domain}/fotografo/${p.slug}/`,
  "name": p.name,
  "jobTitle": "Fotógrafo de bodas",
  "description": "Fotógrafo de bodas en Málaga y Costa del Sol. Estilo documental emocional. Premiado por Fearless Photographers y MyWed #1 Mundial 2019.",
  "url": `https://${site.domain}/fotografo/${p.slug}/`,
  "image": `https://${site.domain}${p.avatar}`,
  "areaServed": [
    { "@type": "City", "name": "Málaga" },
    { "@type": "City", "name": "Marbella" },
    { "@type": "AdministrativeArea", "name": "Andalucía" },
  ],
  "knowsAbout": ["Fotografía de bodas documental", "Fotografía de destino", "Fine art wedding photography"],
  "award": p.awards,
  "sameAs": [`https://instagram.com/${p.instagram}`, p.web],
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `https://${site.domain}/` },
    { "@type": "ListItem", "position": 2, "name": "Málaga", "item": `https://${site.domain}/malaga/` },
    { "@type": "ListItem", "position": 3, "name": p.name, "item": `https://${site.domain}/fotografo/${p.slug}/` },
  ],
};

const schemaFaq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
};
---

<BaseLayout
  title="Albert Pamies — Fotógrafo de Bodas en Málaga · Costa del Sol · 2026"
  description="Albert Pamies, fotógrafo de bodas en Málaga. 12 años, +200 bodas, estilo documental emocional. Fearless Photographers USA · MyWed #1 Mundial 2019. Consulta disponibilidad."
  canonical={`https://${site.domain}/fotografo/${p.slug}/`}
  schema={schemaOrg}
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2]">

    <!-- HERO portada -->
    <section class="relative h-[80vh] min-h-[560px] overflow-hidden bg-[#1C1814]">
      <img
        src={p.coverImage}
        alt="Albert Pamies fotógrafo de bodas en Málaga — documental emocional"
        class="w-full h-full object-cover opacity-80"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#1C1814] via-[#1C1814]/20 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 pb-14">
        <nav class="flex items-center gap-2 font-['Lato'] text-xs text-white/40 mb-6">
          <a href="/" class="hover:text-[#B89060] transition-colors">Inicio</a>
          <span>›</span>
          <a href="/malaga/" class="hover:text-[#B89060] transition-colors">Málaga</a>
          <span>›</span>
          <span class="text-[#B89060]">Albert Pamies</span>
        </nav>
        <div class="flex items-end gap-6">
          <img
            src={p.avatar}
            alt="Albert Pamies"
            class="w-20 h-20 rounded-full object-cover border-2 border-[#B89060] shrink-0 shadow-xl"
            loading="eager"
          />
          <div>
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] mb-1">
              Fotógrafo de bodas verificado · Málaga
            </p>
            <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-7xl font-semibold text-white leading-none mb-2">
              Albert Pamies
            </h1>
            <p class="font-['Lato'] text-white/60 text-sm italic">"{p.tagline}"</p>
          </div>
        </div>
      </div>
    </section>

    <!-- META BAR -->
    <div class="bg-[#1C1814] border-b border-[#2E2520] sticky top-0 z-40">
      <div class="max-w-5xl mx-auto px-6 py-3 flex flex-wrap items-center gap-4 md:gap-8">
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Estilo:</strong> {p.style}</span>
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Zona:</strong> {p.zone}</span>
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Experiencia:</strong> {p.yearsExp} años</span>
        <div class="ml-auto">
          <a
            href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Albert%20Pamies%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
            target="_blank" rel="noopener noreferrer"
            class="btn-gold text-xs py-2 px-4"
          >
            Consultar disponibilidad
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16">

      <!-- TIRA FOTOGRÁFICA inicial: 3 fotos en masonry -->
      <section class="mb-20">
        <div class="columns-3 gap-2">
          {[
            { src: '/images/photographers/albert/ap01.webp', alt: 'Boda en Málaga — Albert Pamies fotógrafo documental' },
            { src: '/images/photographers/albert/ap02.webp', alt: 'Fotografía documental de bodas — Albert Pamies' },
            { src: '/images/photographers/albert/ap03.webp', alt: 'Fotografia de boda Albert Pamies — Málaga' },
          ].map(img => (
            <img src={img.src} alt={img.alt}
              class="w-full mb-2 rounded-sm block"
              loading="lazy" decoding="async" />
          ))}
        </div>
        <p class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">
          Fotos: <a href={p.web} target="_blank" rel="noopener noreferrer nofollow" class="hover:underline text-[#B89060]">albertpamies.com</a>
        </p>
      </section>

      <!-- ARTÍCULO EDITORIAL + SIDEBAR -->
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-20">
        <div class="lg:col-span-2 space-y-10">

          <div>
            <p class="section-eyebrow mb-4">Sobre Albert Pamies</p>
            <h2 class="font-['Cormorant_Garamond'] text-4xl font-semibold text-[#1C1814] mb-6 leading-snug">
              Doce años documentando<br/>lo que no se puede repetir
            </h2>
            <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
              <p>
                Albert Pamies lleva más de doce años fotografiando bodas en Málaga y la Costa del Sol. En ese tiempo ha construido un palmarés internacional poco habitual: premiado por Fearless Photographers en Estados Unidos, número uno mundial por MyWed en 2019, reconocido por Inspiration Photographers en Brasil. Son datos que hablan de un nivel técnico y artístico fuera de lo habitual. Pero lo que de verdad distingue su trabajo no son los premios, sino algo que se nota en cuanto ves una boda completa suya: la capacidad de estar exactamente donde hay que estar en el momento exacto en que algo importante ocurre.
              </p>
              <p>
                Su estilo es documental en la médula. No pide poses, no detiene la ceremonia para reencuadrar, no organiza grupos de invitados junto a la piscina. Se funde entre la gente y fotografía lo que pasa, con la confianza de quien sabe que lo que pasa siempre vale la pena si se mira desde el ángulo correcto.
              </p>
            </div>
          </div>

          <!-- FOTO ANCHA intercalada -->
          <figure>
            <img
              src="/images/photographers/albert/ap04.webp"
              alt="Fotógrafo de bodas Albert Pamies — Costa del Sol Málaga"
              class="w-full rounded-sm block"
              loading="lazy" decoding="async"
            />
            <figcaption class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">© albertpamies.com</figcaption>
          </figure>

          <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814]">
              La luz mediterránea como ventaja técnica real
            </h3>
            <p>
              Almayate, el pueblo donde nació Albert, está a media hora de Málaga capital. Creció con la luz mediterránea, la conoce en cada estación y a cada hora del día. Eso no es un dato de marketing: es una ventaja operativa concreta cuando tienes que fotografiar una boda en una finca de Ronda con el sol de agosto a plomo, o en los jardines de Marbella a las seis de la tarde de octubre, con esa luz dorada que dura veinte minutos y luego desaparece para siempre.
            </p>
            <p>
              La provincia de Málaga tiene una diversidad de escenarios que pocos territorios españoles igualan: playas de Nerja, cortijos del Guadalhorce, palacios del centro histórico, fincas de la Axarquía, villas de la Costa del Sol. Albert ha fotografiado bodas en todos esos entornos. Sabe qué hora tiene cada lugar, dónde hay sombra en julio y dónde llega la última luz en enero. Ese conocimiento geográfico y lumínico se traduce directamente en fotos mejores.
            </p>
          </div>

          <!-- DOS FOTOS en masonry 2 columnas -->
          <div class="columns-2 gap-2">
            {[
              { src: '/images/photographers/albert/ap05.webp', alt: 'Boda en finca Málaga — Albert Pamies reportaje' },
              { src: '/images/photographers/albert/ap06.webp', alt: 'Momento boda Costa del Sol — Albert Pamies' },
            ].map(img => (
              <img src={img.src} alt={img.alt}
                class="w-full mb-2 rounded-sm block"
                loading="lazy" decoding="async" />
            ))}
          </div>

          <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814]">
              Cómo trabaja Albert el día de vuestra boda
            </h3>
            <p>
              La mayoría de los fotógrafos de boda llegan con un plan. Albert llega con una actitud. Su objetivo, si se puede llamar así, es estar siempre en el lugar correcto sin que nadie le vea llegar. Eso requiere una lectura constante del espacio y de las personas que hay en él.
            </p>
            <p>
              Durante los preparativos trabaja en paralelo con los novios, siguiendo el ritmo natural de la mañana sin imponer el suyo. En la ceremonia se mueve con discreción por los márgenes, buscando los ángulos que capturan la expresión de quien escucha tanto como la de quien habla. En el cóctel desaparece entre los invitados. En el baile está en medio de todo.
            </p>
            <p>
              La sesión de pareja, que suele hacerse durante el cóctel o justo antes del atardecer, es el único momento en que trabaja de forma más dirigida. No es una sesión de poses, pero sí de intención: busca un lugar con buena luz, os da espacio y espera a que ocurra algo real. Una mirada, una carcajada, un silencio. Lo que sea, siempre que sea verdad.
            </p>
          </div>

          <!-- FOTO individual a ancho completo -->
          <figure>
            <img
              src="/images/photographers/albert/ap07.webp"
              alt="Ceremonia boda Málaga — Albert Pamies fotógrafo documental"
              class="w-full rounded-sm block"
              loading="lazy" decoding="async"
            />
            <figcaption class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">© albertpamies.com</figcaption>
          </figure>

          <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
            <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814]">
              La entrega: qué recibiréis y cuándo
            </h3>
            <p>
              Un reportaje completo con Albert cubre el día íntegro, desde los preparativos hasta el cierre del baile. Las fotos se entregan en galería privada online, en alta resolución, sin marca de agua, con derechos de uso personal completos. La media está entre 500 y 800 fotografías seleccionadas con criterio, no entregadas en bloque.
            </p>
            <p>
              La sesión preboda es optativa pero muy recomendable. Una hora o dos antes de la boda, en una localización elegida por vosotros, sin agenda ni invitados. Sirve para que el fotógrafo os conozca en un contexto relajado y para llegar al gran día con una relación de confianza ya establecida. La diferencia en las fotos es visible.
            </p>
            <p>
              Albert viaja a toda España y Europa. Para fechas en temporada alta en la Costa del Sol (mayo a octubre), la lista de espera puede superar los doce meses. Si tenéis fecha, consultad disponibilidad cuanto antes.
            </p>
          </div>

          <!-- DOS FOTOS individuales finales -->
          <figure>
            <img
              src="/images/photographers/albert/ap08.webp"
              alt="Postboda en Santorini — Albert Pamies fotógrafo de destino"
              class="w-full rounded-sm block"
              loading="lazy" decoding="async"
            />
            <figcaption class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">© albertpamies.com</figcaption>
          </figure>
          <figure>
            <img
              src="/images/photographers/albert/ap09.webp"
              alt="Sesión preboda — Albert Pamies fotógrafo Málaga"
              class="w-full rounded-sm block"
              loading="lazy" decoding="async"
            />
            <figcaption class="font-['Lato'] text-[10px] text-[#9A8880] text-right mt-2">© albertpamies.com</figcaption>
          </figure>

        </div>

        <!-- SIDEBAR -->
        <div class="space-y-5 lg:sticky lg:top-20 self-start">
          <div class="bg-[#1C1814] rounded-sm p-6 text-white">
            <p class="font-['Cormorant_Garamond'] text-2xl font-semibold mb-3">¿Queréis a Albert?</p>
            <p class="font-['Lato'] text-sm text-[#9A8880] leading-relaxed mb-5">
              Consultadnos fecha y ciudad. Confirmamos disponibilidad en menos de 24 horas.
            </p>
            <a
              href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Albert%20Pamies%20para%20mi%20boda%20en%20Málaga.%20¿Podéis%20consultarme%20disponibilidad%3F`}
              target="_blank" rel="noopener noreferrer"
              class="btn-gold w-full text-sm py-3 text-center block"
            >
              Consultar por WhatsApp →
            </a>
            <p class="font-['Lato'] text-[10px] text-[#6B5E58] text-center mt-3">Sin compromiso · Gratis</p>
          </div>

          <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">Reconocimientos</p>
            <ul class="space-y-3">
              {p.awards.map(a => (
                <li class="flex items-start gap-3">
                  <span class="text-[#B89060] mt-0.5 shrink-0">★</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814] leading-snug">{a}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">En cifras</p>
            <ul class="space-y-4">
              {[
                { n: '+12', label: 'años fotografiando bodas' },
                { n: '+200', label: 'bodas documentadas' },
                { n: '+50', label: 'bodas de destino' },
                { n: '500–800', label: 'fotos editadas por boda' },
                { n: '6 sem.', label: 'tiempo de entrega' },
              ].map(s => (
                <li class="flex items-baseline justify-between gap-2 border-b border-[#E8DDD3] pb-3 last:border-0 last:pb-0">
                  <span class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#B89060]">{s.n}</span>
                  <span class="font-['Lato'] text-xs text-[#6B5E58] text-right">{s.label}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-white border border-[#E8DDD3] rounded-sm p-6 text-center">
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-3">Zona de cobertura</p>
            <p class="font-['Cormorant_Garamond'] text-lg text-[#1C1814] leading-relaxed">
              Málaga · Marbella<br/>Costa del Sol · Ronda<br/>Axarquía · España<br/>Europa
            </p>
          </div>
        </div>
      </section>

      <!-- SERVICIOS -->
      <section class="mb-20">
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Qué incluye</p>
          <h2 class="section-title">Lo que recibiréis</h2>
          <span class="gold-divider"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            { title: 'Cobertura del día completo', desc: 'Desde los preparativos hasta el cierre del baile. Sin límite de horas ni cargo adicional por duración.' },
            { title: 'Sesión preboda', desc: 'Una sesión previa en la localización que elijáis. Para llegar relajados y con la cámara ya como una amiga.' },
            { title: 'Galería privada online', desc: 'Entre 500 y 800 imágenes editadas en alta resolución, sin marca de agua, con derechos de uso personal completos.' },
            { title: 'Bodas de destino', desc: 'Cubre toda España y Europa. Más de 50 bodas de destino documentadas. Presupuesto personalizado por ubicación.' },
          ].map(s => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-2">{s.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-20">
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Preguntas frecuentes</p>
          <h2 class="section-title">Todo lo que necesitáis saber<br/>sobre Albert Pamies</h2>
          <span class="gold-divider"></span>
        </div>
        <div class="max-w-3xl mx-auto space-y-4">
          {faq.map(item => (
            <details class="bg-white border border-[#E8DDD3] rounded-sm group">
              <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
                <span class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] leading-snug">
                  {item.q}
                </span>
                <span class="text-[#B89060] shrink-0 text-xl font-light group-open:rotate-45 transition-transform duration-200">+</span>
              </summary>
              <div class="px-6 pb-5 font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- CTA FINAL -->
      <section class="bg-[#1C1814] rounded-sm p-10 md:p-16 text-center">
        <p class="section-eyebrow text-[#B89060] mb-4">¿Conectamos?</p>
        <h2 class="font-['Cormorant_Garamond'] text-4xl font-semibold text-white mb-4">
          Consultad disponibilidad<br/>sin compromiso
        </h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#9A8880] mt-6 mb-8 max-w-md mx-auto leading-relaxed text-sm">
          Contadnos vuestra fecha y dónde es la boda. Confirmamos si Albert está disponible y os enviamos toda la información.
        </p>
        <a
          href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Albert%20Pamies%20para%20mi%20boda%20en%20Málaga.%20¿Podéis%20consultarme%20disponibilidad%3F`}
          target="_blank" rel="noopener noreferrer"
          class="btn-gold text-base px-10 py-4 inline-flex items-center gap-3"
        >
