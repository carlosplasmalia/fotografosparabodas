---

<BaseLayout
  title="Chema Vela · Plasmalia — Fotógrafo de Bodas en Madrid · Fine Art · 2026"
  description="Plasmalia (Chema Vela), fotógrafo de bodas en Madrid. 15 años, +300 bodas, fine art editorial. Fearless Top 30 Worldwide · ISPWP · Junebug. 4.8★ Google. Consulta gratis."
  canonical={`https://${site.domain}/fotografo/${p.slug}/`}
  schema={schemaOrg}
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2]">

    <!-- HERO portada full-bleed -->
    <section class="relative h-[85vh] min-h-[600px] overflow-hidden bg-[#1C1814]">
      <img
        src={p.coverImage}
        alt="Plasmalia — Chema Vela, fotógrafo de bodas en Madrid, estilo fine art editorial"
        class="w-full h-full object-cover opacity-85"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#1C1814] via-[#1C1814]/10 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 pb-14">
        <nav class="flex items-center gap-2 font-['Lato'] text-xs text-white/40 mb-8">
          <a href="/" class="hover:text-[#8B6A3A] transition-colors">Inicio</a>
          <span>›</span>
          <a href="/madrid/" class="hover:text-[#8B6A3A] transition-colors">Madrid</a>
          <span>›</span>
          <span class="text-[#8B6A3A]">Plasmalia · Chema Vela</span>
        </nav>
        <div class="flex items-end gap-6">
          <img
            src={p.avatar}
            alt="Plasmalia — estudio de fotografía de bodas en Madrid"
            class="w-20 h-20 rounded-full object-contain border-2 border-[#8B6A3A] shrink-0 shadow-xl bg-white p-2"
            loading="eager"
          />
          <div>
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] mb-1">
              Fotógrafo verificado · Madrid · 4.8★ Google
            </p>
            <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-7xl font-semibold text-white leading-none mb-1">
              Plasmalia
            </h1>
            <p class="font-['Cormorant_Garamond'] text-2xl text-white/60 font-light mb-3">Chema Vela</p>
            <div class="flex flex-wrap gap-2">
              {p.awards.slice(0,2).map(a => (
                <span class="font-['Lato'] text-[10px] px-2 py-1 bg-[#8B6A3A]/20 border border-[#8B6A3A]/40 text-[#F2E8D5] rounded-sm">★ {a}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- META BAR sticky -->
    <div class="bg-[#1C1814] border-b border-[#2E2520] sticky top-0 z-40">
      <div class="max-w-5xl mx-auto px-6 py-3 flex flex-wrap items-center gap-4 md:gap-8">
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Estilo:</strong> {p.style}</span>
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Zona:</strong> {p.zone}</span>
        <span class="font-['Lato'] text-xs text-[#9A8880]"><strong class="text-[#C4A5A0]">Experiencia:</strong> +{p.yearsExp} años</span>
        <div class="ml-auto">
          <a href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Chema%20Vela%20(Plasmalia)%20para%20mi%20boda%20en%20Madrid.%20¿Podéis%20consultarme%20disponibilidad%3F`}
