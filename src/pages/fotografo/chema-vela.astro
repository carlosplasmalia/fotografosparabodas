import { site } from '../../config/site';

const p = {
  name: 'Chema Vela · Plasmalia',
  slug: 'chema-vela',
  city: 'Madrid',
  citySlug: 'madrid',
  zone: 'Madrid · Castilla · España · Internacional',
  style: 'Fine art · Editorial',
  tagline: 'Fotografía de boda de autor: composición, luz y emoción en cada frame.',
  yearsExp: 15,
  instagram: 'plasmalia',
  web: 'https://plasmalia.es',
  avatar: '/images/photographers/plasmalia/logo.webp',
