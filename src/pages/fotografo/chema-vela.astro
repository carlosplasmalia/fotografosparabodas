---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const p = {
  name: 'Chema Vela · Plasmalia',
  slug: 'chema-vela',
  city: 'Madrid',
  citySlug: 'madrid',
  zone: 'Madrid · Toledo · Castilla · España',
  style: 'Fine art · Editorial',
  tagline: 'Fotografía de boda de autor: composición, luz y emoción en cada frame.',
  price: 'Consultar disponibilidad',
  yearsExp: 15,
  instagram: 'plasmalia',
  web: 'https://plasmalia.es',
  avatar: '/images/photographers/plasmalia/logo.webp',
  coverImage: '/images/photographers/plasmalia/foto1.jpg',
  portfolio: [
    { src: '/images/photographers/plasmalia/foto1.jpg', alt: 'Boda en Madrid — Plasmalia' },
    { src: '/images/photographers/plasmalia/foto2.jpg', alt: 'Fotografía de autor boda — Chema Vela' },
    { src: '/images/photographers/plasmalia/foto3.webp', alt: 'Fine art bodas Madrid — Plasmalia' },
    { src: '/images/photographers/plasmalia/foto4.webp', alt: 'Boda editorial Madrid — Plasmalia' },
    { src: '/images/portfolio/malaga-1.jpg',            alt: 'Detalles de boda — Plasmalia' },
    { src: '/images/portfolio/malaga-3.jpg',            alt: 'Ceremonia boda Madrid — Chema Vela' },
  ],
  awards: [
    'Fearless Photographers Top 30 Worldwide',
    'ISPWP Top Wedding Photographer',
    'Junebug Weddings Best of 2024',
    'SMP Little Black Book',
  ],
  bio: `Chema Vela es el fotógrafo detrás de Plasmalia, uno de los estudios de fotografía de bodas de mayor reconocimiento internacional en España. Con más de 15 años de experiencia y cientos de bodas documentadas en Madrid, Castilla, el Mediterráneo y destinos de toda Europa, su trabajo ha aparecido en las principales plataformas de referencia del sector.

Su estilo combina el fine art con una narrativa documental que captura la emoción real del día sin artificios. Las bodas que fotografía Chema tienen una coherencia visual muy reconocible: tonos cálidos, composiciones limpias y una atención a la luz que transforma cualquier escenario en algo memorable.

Trabaja con una agenda muy limitada para garantizar la dedicación total a cada pareja. Si queréis trabajar con Chema, contactad con la máxima antelación posible.`,
  services: [
    { title: 'Reportaje de boda completo', desc: 'Cobertura íntegra desde los preparativos hasta el baile. Sin horas extra.' },
    { title: 'Sesión preboda fine art', desc: 'Una sesión previa con dirección creativa para que os sintáis naturales delante de la cámara.' },
    { title: 'Galería online y entrega en alta resolución', desc: 'Entre 600 y 1.000 imágenes editadas, entregadas en galería privada en 8 semanas.' },
    { title: 'Bodas de destino en España y Europa', desc: 'Madrid, Castilla, costa mediterránea, Portugal, Italia y más. Presupuesto personalizado según ubicación.' },
  ],
};

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://${site.domain}/fotografo/${p.slug}/`,
  "name": "Plasmalia — Chema Vela",
  "description": p.tagline,
  "url": `https://${site.domain}/fotografo/${p.slug}/`,
  "areaServed": [
    { "@type": "City", "name": "Madrid" },
    { "@type": "AdministrativeArea", "name": "Castilla" },
    { "@type": "Country", "name": "España" },
  ],
  "knowsAbout": "Fotografía de bodas fine art",
  "award": p.awards,
  "sameAs": [
    `https://instagram.com/${p.instagram}`,
    p.web,
  ],
};
---

<BaseLayout
  title="Chema Vela · Plasmalia — Fotógrafo de Bodas en Madrid | fotografosparabodas.es"
  description="Plasmalia (Chema Vela), fotógrafo de bodas en Madrid con 15 años de experiencia. Fine art y editorial. Premiado internacionalmente. Consulta disponibilidad."
  canonical={`https://${site.domain}/fotografo/${p.slug}/`}
  schema={schemaOrg}
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2]">

    <section class="relative h-[70vh] min-h-[480px] overflow-hidden bg-[#1C1814]">
      <img
        src={p.coverImage}
        alt={`${p.name} — fotógrafo de bodas en ${p.city}`}
        class="w-full h-full object-cover opacity-70"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#1C1814] via-transparent to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 pb-12">
        <div class="flex items-end gap-6">
          <img
            src={p.avatar}
            alt={p.name}
            class="w-20 h-20 rounded-full object-cover border-2 border-[#B89060] shrink-0 shadow-xl bg-white p-1"
            loading="eager"
          />
          <div>
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] mb-1">
              Fotógrafo verificado · {p.city}
            </p>
            <h1 class="font-['Cormorant_Garamond'] text-4xl md:text-5xl font-semibold text-white leading-none mb-2">
              Plasmalia<br/><span class="text-2xl text-white/70 font-normal">Chema Vela</span>
            </h1>
            <p class="font-['Lato'] text-white/70 text-base italic">
              "{p.tagline}"
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="bg-[#1C1814] border-b border-[#2E2520]">
      <div class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Estilo</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.style}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Zona</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.zone}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Experiencia</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.yearsExp} años</span>
        </div>
        <div class="ml-auto">
          <a
            href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20el%20fotógrafo%20Chema%20Vela%20(Plasmalia)%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold text-sm py-2.5 px-5"
          >
            Consultar disponibilidad
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 space-y-20">

      <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="section-eyebrow mb-4">Sobre el fotógrafo</p>
          <h2 class="section-title mb-6">Quince años<br/>de fotografía de autor</h2>
          {p.bio.split('\n\n').map(para => (
            <p class="font-['Lato'] text-[#6B5E58] text-sm leading-loose mb-4">{para}</p>
          ))}
          <p class="font-['Lato'] text-xs text-[#9A8880] mt-2">
            Fotos: <a href={p.web} target="_blank" rel="noopener noreferrer nofollow" class="text-[#B89060] hover:underline">{p.web}</a>
          </p>
        </div>

        <div class="space-y-6">
          <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">Reconocimientos</p>
            <ul class="space-y-3">
              {p.awards.map(a => (
                <li class="flex items-center gap-3">
                  <span class="text-[#B89060]">🏆</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814]">{a}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-[#1C1814] rounded-sm p-6 text-white">
            <p class="font-['Cormorant_Garamond'] text-2xl font-semibold mb-3">¿Queréis trabajar con Chema?</p>
            <p class="font-['Lato'] text-sm text-[#9A8880] leading-relaxed mb-5">
              Consultadnos fecha, ciudad y tipo de boda. Confirmamos disponibilidad en menos de 24 horas.
            </p>
            <a
              href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Chema%20Vela%20(Plasmalia)%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-gold w-full text-sm py-3 text-center block"
            >
              Consultar disponibilidad →
            </a>
            <p class="font-['Lato'] text-[10px] text-[#6B5E58] text-center mt-3">
              Sin compromiso · Respuesta en 24 horas
            </p>
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-baseline justify-between mb-8">
          <div>
            <p class="section-eyebrow mb-2">Portfolio</p>
            <h2 class="section-title">Trabajo reciente</h2>
          </div>
          <a
            href={`https://instagram.com/${p.instagram}`}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] hover:underline"
          >
            Ver más en IG →
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
          {p.portfolio.map((img, i) => (
            <div class:list={[
              "overflow-hidden rounded-sm bg-[#E8DDD3]",
              i === 0 ? "col-span-2 md:col-span-2 row-span-2 aspect-[4/3]" : "aspect-square"
            ]}>
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading={i < 3 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}
        </div>
      </section>

      <section>
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Lo que incluye</p>
          <h2 class="section-title">Servicios y paquetes</h2>
          <span class="gold-divider"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {p.services.map(s => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-2">{s.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-[#F2E8D5] rounded-sm p-10 text-center">
        <p class="section-eyebrow mb-4">¿Conectamos?</p>
        <h2 class="section-title mb-4">Consultad disponibilidad<br/>sin compromiso</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 max-w-md mx-auto leading-relaxed text-sm">
          Contadnos vuestra fecha y dónde es la boda. Confirmamos si Chema está disponible y os enviamos toda la información.
        </p>
        <a
          href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Chema%20Vela%20(Plasmalia)%20para%20mi%20boda%20en%20Madrid.%20¿Podéis%20consultarme%20disponibilidad%3F`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold text-base px-10 py-4 inline-flex items-center gap-3"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Consultar por WhatsApp
        </a>
        <p class="font-['Lato'] text-xs text-[#9A8880] mt-4">
          O vuelve al directorio de <a href={`/${p.citySlug}/`} class="text-[#B89060] hover:underline">fotógrafos en {p.city}</a>
        </p>
      </section>

    </div>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={p.city} />
</BaseLayout>
