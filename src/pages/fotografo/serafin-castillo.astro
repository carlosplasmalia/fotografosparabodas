---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const p = {
  name: 'Serafín Castillo',
  slug: 'serafin-castillo',
  city: 'Marbella',
  citySlug: 'malaga',
  zone: 'Marbella · Costa del Sol · España · Internacional',
  style: 'Fine art documental',
  tagline: 'Film y digital, elegancia mediterránea atemporal.',
  price: 'desde 2.000€',
  yearsExp: 10,
  instagram: 'serafin_castillo',
  web: 'https://www.serafincastillo.com',
  avatar: '/images/photographers/albert/avatar.webp',
  coverImage: '/images/photographers/albert/ap07.webp',
  portfolio: [
    { src: '/images/photographers/albert/ap01.webp', alt: 'Boda en la Costa del Sol — fotografía documental' },
    { src: '/images/photographers/albert/ap03.webp', alt: 'Fotografía boda Marbella — fine art documental' },
    { src: '/images/photographers/albert/ap08.webp', alt: 'Postboda mediterráneo — fotografía de destino' },
    { src: '/images/photographers/albert/ap09.webp', alt: 'Sesión preboda Costa del Sol' },
    { src: '/images/photographers/plasmalia/p01.webp', alt: 'Fine art boda en blanco y negro' },
    { src: '/images/photographers/plasmalia/p04.webp', alt: 'Reportaje postboda exterior' },
  ],
  awards: [
    'Reconocido por Vogue Weddings',
    'Fearless Photographers',
    'Destination Wedding Photographers Global',
  ],
  bio: `Serafín Castillo nació en Nerja y tiene su base en Marbella. Lleva más de diez años fotografiando bodas en la Costa del Sol, toda España y destinos internacionales. Su trabajo aparece regularmente en publicaciones como Vogue, y su Instagram con más de 50.000 seguidores es referencia en la fotografía de bodas de alta gama.

Su estilo combina la sensibilidad del film analógico con la precisión técnica del digital. El resultado tiene una calidez y una elegancia que recuerda a las grandes fotos de las revistas de moda, pero con la emoción real de un reportaje de boda.

Serafín trabaja con una agenda muy selectiva. Fotografía pocas bodas al año para dedicar a cada una el nivel de atención que merece. Si vuestra celebración tiene un marcado carácter estético y buscáis algo más que un reportaje convencional, es la persona adecuada.`,
  services: [
    { title: 'Reportaje fine art de boda completo', desc: 'Cobertura total del día con el sello visual característico de Serafín. Desde preparativos hasta cierre.' },
    { title: 'Sesión preboda o trash the dress', desc: 'Una sesión artística previa o posterior a la boda para explorar localizaciones con tiempo y sin agenda.' },
    { title: 'Galería privada y álbum artesanal', desc: 'Entrega en alta resolución y opción de álbum impreso de autor. Los mejores fabricantes de Europa.' },
    { title: 'Bodas de destino', desc: 'Costa del Sol, Andalucía, Baleares, Italia, Portugal y más. Presupuesto personalizado.' },
  ],
};

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `https://${site.domain}/fotografo/${p.slug}/`,
  "name": p.name,
  "description": p.tagline,
  "url": `https://${site.domain}/fotografo/${p.slug}/`,
  "areaServed": [
    { "@type": "City", "name": "Marbella" },
    { "@type": "City", "name": "Málaga" },
    { "@type": "AdministrativeArea", "name": "Andalucía" },
  ],
  "knowsAbout": "Fotografía de bodas fine art",
  "award": p.awards,
  "sameAs": [
    `https://instagram.com/${p.instagram}`,
    p.web,
  ],
};
---

<BaseLayout
  title="Serafín Castillo — Fotógrafo de Bodas en Marbella | fotografosparabodas.es"
  description="Serafín Castillo, fotógrafo de bodas fine art en Marbella y Costa del Sol. Reconocido por Vogue. 51K seguidores. Bodas de destino internacionales. Consulta disponibilidad."
  canonical={`https://${site.domain}/fotografo/${p.slug}/`}
  schema={schemaOrg}
>
  <SiteHeader />
  <main class="pt-16 bg-[#FAF7F2]">

    <section class="relative h-[70vh] min-h-[480px] overflow-hidden bg-[#1C1814]">
      <img
        src={p.coverImage}
        alt={`${p.name} — fotógrafo de bodas en ${p.city}`}
        class="w-full h-full object-cover opacity-70"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#1C1814] via-transparent to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 max-w-5xl mx-auto px-6 pb-12">
        <div class="flex items-end gap-6">
          <img
            src={p.avatar}
            alt={p.name}
            class="w-20 h-20 rounded-full object-cover border-2 border-[#8B6A3A] shrink-0 shadow-xl"
            loading="eager"
          />
          <div>
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] mb-1">
              Fotógrafo verificado · {p.city}
            </p>
            <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-semibold text-white leading-none mb-2">
              {p.name}
            </h1>
            <p class="font-['Lato'] text-white/70 text-base italic">
              "{p.tagline}"
            </p>
          </div>
        </div>
      </div>
    </section>

    <div class="bg-[#1C1814] border-b border-[#2E2520]">
      <div class="max-w-5xl mx-auto px-6 py-4 flex flex-wrap items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Estilo</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.style}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Zona</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.zone}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58]">Experiencia</span>
          <span class="font-['Lato'] text-sm text-[#C4A5A0]">{p.yearsExp} años</span>
        </div>
        <div class="ml-auto">
          <a
            href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20el%20fotógrafo%20Serafín%20Castillo%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold text-sm py-2.5 px-5"
          >
            Consultar disponibilidad
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-16 space-y-20">

      <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="section-eyebrow mb-4">Sobre el fotógrafo</p>
          <h2 class="section-title mb-6">De Nerja al mundo,<br/>con la Costa del Sol de base</h2>
          {p.bio.split('\n\n').map(para => (
            <p class="font-['Lato'] text-[#6B5E58] text-sm leading-loose mb-4">{para}</p>
          ))}
          <p class="font-['Lato'] text-xs text-[#9A8880] mt-2">
            Fotos: <a href={p.web} target="_blank" rel="noopener noreferrer nofollow" class="text-[#8B6A3A] hover:underline">{p.web}</a>
          </p>
        </div>

        <div class="space-y-6">
          <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
            <p class="section-eyebrow mb-4">Reconocimientos</p>
            <ul class="space-y-3">
              {p.awards.map(a => (
                <li class="flex items-center gap-3">
                  <span class="text-[#8B6A3A]">🏆</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814]">{a}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-[#1C1814] rounded-sm p-6 text-white">
            <p class="font-['Cormorant_Garamond'] text-2xl font-semibold mb-3">¿Queréis trabajar con Serafín?</p>
            <p class="font-['Lato'] text-sm text-[#9A8880] leading-relaxed mb-5">
              Consultadnos fecha y localización. Confirmamos disponibilidad en menos de 24 horas.
            </p>
            <a
              href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Serafín%20Castillo%20para%20mi%20boda.%20¿Podéis%20consultarme%20disponibilidad%3F`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn-gold w-full text-sm py-3 text-center block"
            >
              Consultar disponibilidad →
            </a>
            <p class="font-['Lato'] text-[10px] text-[#6B5E58] text-center mt-3">
              Sin compromiso · Respuesta en 24 horas
            </p>
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-baseline justify-between mb-8">
          <div>
            <p class="section-eyebrow mb-2">Portfolio</p>
            <h2 class="section-title">Trabajo reciente</h2>
          </div>
          <a
            href={`https://instagram.com/${p.instagram}`}
            target="_blank"
            rel="noopener noreferrer nofollow"
            class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] hover:underline"
          >
            Ver más en IG →
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
          {p.portfolio.map((img, i) => (
            <div class:list={[
              "overflow-hidden rounded-sm bg-[#E8DDD3]",
              i === 0 ? "col-span-2 md:col-span-2 row-span-2 aspect-[4/3]" : "aspect-square"
            ]}>
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                loading={i < 3 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}
        </div>
      </section>

      <section>
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Lo que incluye</p>
          <h2 class="section-title">Servicios y paquetes</h2>
          <span class="gold-divider"></span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {p.services.map(s => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-2">{s.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="bg-[#F2E8D5] rounded-sm p-10 text-center">
        <p class="section-eyebrow mb-4">¿Conectamos?</p>
        <h2 class="section-title mb-4">Consultad disponibilidad<br/>sin compromiso</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 max-w-md mx-auto leading-relaxed text-sm">
          Contadnos vuestra fecha y dónde es la boda. Confirmamos si Serafín está disponible ese día.
        </p>
        <a
          href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20me%20interesa%20Serafín%20Castillo%20para%20mi%20boda%20en%20Marbella.%20¿Podéis%20consultarme%20disponibilidad%3F`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-gold text-base px-10 py-4 inline-flex items-center gap-3"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Consultar por WhatsApp
        </a>
        <p class="font-['Lato'] text-xs text-[#9A8880] mt-4">
          O vuelve al directorio de <a href={`/${p.citySlug}/`} class="text-[#8B6A3A] hover:underline">fotógrafos en Málaga</a>
        </p>
      </section>

    </div>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={p.city} />
</BaseLayout>
