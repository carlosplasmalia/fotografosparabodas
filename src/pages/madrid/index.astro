---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import PhotographerProfile from '../../components/PhotographerProfile.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import type { PhotographerFull } from '../../components/PhotographerProfile.astro';

const city = 'Madrid';
const slug = 'madrid';

const photographers: PhotographerFull[] = [
  {
    name: 'Plasmalia — Chema Vela',
    city: 'Madrid',
    zone: 'Madrid · Castilla · España · Internacional',
    style: 'Fine art · Editorial',
    styleDesc: 'Composición de autor, luz trabajada, fotos que duran generaciones',
    bio: 'Chema Vela lleva más de 15 años fotografiando bodas en Madrid y toda España. Su estudio Plasmalia es referencia internacional en fine art y fotografía editorial de bodas. Premiado por Fearless Photographers, ISPWP y Junebug Weddings. Agenda muy limitada.',
    avatar: '/images/photographers/plasmalia/logo.webp',
    portfolio: [
      { src: '/images/photographers/plasmalia/foto1.jpg', alt: 'Boda en Madrid — Plasmalia' },
      { src: '/images/photographers/plasmalia/foto2.jpg', alt: 'Fine art bodas Madrid — Chema Vela' },
      { src: '/images/photographers/plasmalia/foto3.webp', alt: 'Editorial boda Madrid — Plasmalia' },
    ],
    web: 'https://plasmalia.es',
    instagram: 'plasmalia',
    profileSlug: 'chema-vela',
    badge: 'Verificado',
    yearsExp: 15,
    awards: ['Fearless Photographers Top 30 Worldwide', 'ISPWP Top Wedding Photographer', 'Junebug Weddings Best of 2024'],
    photoCredit: 'Plasmalia.es',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Fotógrafos de bodas en ${city}`,
  "description": `Los mejores fotógrafos de bodas en ${city}, seleccionados a mano. Solo fotógrafos con premios internacionales y trayectoria verificada.`,
  "url": `https://fotografosparabodas.es/${slug}/`,
  "numberOfItems": photographers.length,
  "itemListElement": photographers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.name,
      "description": p.bio,
      "areaServed": { "@type": "City", "name": city },
    }
  })),
};
---

<BaseLayout
  title="Fotógrafos de Bodas en Madrid — Selección de Autor 2026"
  description="Los mejores fotógrafos de bodas en Madrid, seleccionados a mano. Solo fotógrafos con premios internacionales y agenda limitada. Contacto directo, sin intermediarios."
  canonical={`https://fotografosparabodas.es/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafos de Bodas\nen Madrid`}
      subtitle="Los mejores fotógrafos de bodas de Madrid, seleccionados a mano. Solo fotógrafos con premios internacionales y trayectoria verificada."
      ctaText="Ver fotógrafos en Madrid"
      ctaHref="#fotografos"
      imageSrc="/images/photographers/plasmalia/fotografo-boda-madrid.webp"
    />

    <!-- Local intro -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Madrid y Comunidad</p>
            <h2 class="section-title mb-6">La capital tiene<br/>los mejores escenarios</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Desde los jardines del Retiro y los palacios del Siglo de Oro hasta las bodegas contemporáneas de las afueras, Madrid ofrece un marco infinito para cada tipo de boda.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              Los fotógrafos de bodas en Madrid están acostumbrados a trabajar en interiores con luz difícil, exteriores con luz dura de verano y los tonos mágicos del atardecer madrileño. Eso se nota en el resultado.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Fotógrafos listados', value: `${photographers.length} verificados` },
                { label: 'Selección', value: 'Solo premiados internacionalmente' },
                { label: 'Temporada alta', value: 'Mayo – Octubre' },
                { label: 'Zonas populares', value: 'Retiro, El Escorial, Chinchón, Moraleja' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Photographers -->
    <section id="fotografos" class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Directorio</p>
          <h2 class="section-title">Fotógrafos de boda<br/>disponibles en Madrid</h2>
          <span class="gold-divider"></span>
        </div>

        <div class="space-y-6">
          {photographers.map((p, i) => <PhotographerProfile photographer={p} featured={i === 0} />)}
        </div>

        <div class="mt-12 bg-white border border-[#E8DDD3] rounded-sm p-8 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mb-3">
            Plaza disponible en Madrid
          </p>
          <p class="font-['Lato'] text-sm text-[#6B5E58] mb-6 max-w-md mx-auto">
            Solo aceptamos 2 fotógrafos por ciudad. Hay una plaza libre. Si tu portfolio encaja, es tuya.
          </p>
          <a href="/unete/" class="btn-gold">Solicitar mi plaza →</a>
        </div>
      </div>
    </section>

    <!-- SEO text -->
    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en Madrid?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            Madrid concentra algunos de los fotógrafos de bodas más premiados de España. La oferta es enorme y la diferencia de calidad también. Por eso nuestra selección es intencionalmente pequeña: solo fotógrafos con premios internacionales contrastados, con años de trayectoria en la ciudad y con un estilo propio reconocible.
          </p>
          <p>
            La temporada alta en Madrid es de mayo a octubre. Para esas fechas, los mejores fotógrafos cierran agenda con más de un año de antelación. Si tenéis fecha confirmada, consultad disponibilidad cuanto antes. Podéis consultar nuestra <a href="/blog/cuanto-cuesta-fotografo-boda-espana-2026/" class="text-[#8B6A3A] underline">guía de precios de fotografía de bodas en España</a> para tener una referencia antes de pedir presupuesto.
          </p>
          <p>
            Los fotógrafos de nuestra red en Madrid cubren bodas en toda la Comunidad: El Escorial, Chinchón, Moraleja, Guadalajara y Toledo, sin desplazamiento adicional. Confirmad siempre este punto al consultar.
          </p>
        </div>
      </div>
    </section>

    <!-- Precio fotógrafo bodas Madrid -->
    <section class="py-16 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6">
        <p class="section-eyebrow mb-4">Fotógrafo bodas Madrid precio</p>
        <h2 class="section-title mb-4">¿Cuánto cuesta un fotógrafo<br/>de bodas en Madrid?</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 leading-relaxed">
          Madrid es una de las ciudades con mayor rango de precios en fotografía de bodas de España. La diferencia entre un fotógrafo sin experiencia y un profesional premiado puede ser enorme, y no siempre se refleja de forma obvia en el portfolio.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { rango: '1.200 – 2.000 €', nivel: 'Iniciación', desc: 'Fotógrafos con menos de 3 años de experiencia en bodas. Portfolio en formación, sin premios internacionales.' },
            { rango: '2.000 – 3.500 €', nivel: 'Intermedio', desc: 'Fotógrafos con trayectoria consolidada, estilo propio y referencias verificables. El rango más común en Madrid.' },
            { rango: '3.500 – 6.000 €', nivel: 'Referencia', desc: 'Fotógrafos con premios internacionales, agenda muy limitada y publicaciones en medios especializados.' },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A] mb-1">{item.rango}</p>
              <p class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#1C1814] mb-3">{item.nivel}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
          Los fotógrafos de nuestra red en Madrid están en el rango intermedio-referencia. Si queréis saber si encajan con vuestro presupuesto,
          <a href="/#contacto" class="text-[#8B6A3A] underline">consultadnos sin compromiso</a> y os orientamos antes de que habléis con nadie.
        </p>
      </div>
    </section>

    <FAQSection city={city} />

    <!-- Related cities -->
    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">Cerca de Madrid</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-8">
          También cubrimos
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Valladolid', slug: 'valladolid' },
            { name: 'Zaragoza', slug: 'zaragoza' },
            { name: 'Bilbao', slug: 'bilbao' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">
              Fotógrafos en {c.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
