---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import PhotographerProfile from '../../components/PhotographerProfile.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import type { PhotographerFull } from '../../components/PhotographerProfile.astro';

const city = 'Málaga';
const slug = 'malaga';

const photographers: PhotographerFull[] = [
  {
    name: 'Albert Pamies',
    city: 'Málaga',
    zone: 'Málaga · Marbella · Costa del Sol',
    style: 'Documental emocional',
    styleDesc: 'Naturalidad, emoción y elegancia sin poses forzadas',
    bio: 'Albert Pamies captura bodas en Málaga y la Costa del Sol con un estilo documental que mezcla emoción y elegancia. Más de 12 años fotografiando historias de amor únicas, reconocido por Fearless Photographers (USA) y clasificado #1 mundial en MyWed en 2019.',
    avatar: '/images/photographers/albert/avatar.webp',
    portfolio: [
      { src: '/images/photographers/albert/ap01.webp', alt: 'Boda en Málaga — Albert Pamies' },
      { src: '/images/photographers/albert/ap03.webp', alt: 'Fotografía de boda Costa del Sol — Albert Pamies' },
      { src: '/images/photographers/albert/ap05.webp', alt: 'Pareja de novios Málaga — Albert Pamies' },
    ],
    web: 'https://albertpamies.com',
    instagram: 'albertpamies',
    profileSlug: 'albert-pamies',
    badge: 'Verificado',
    yearsExp: 12,
    awards: ['Fearless Photographers USA', 'MyWed #1 Mundial 2019', 'Inspiration Photographers Brazil'],
    photoCredit: 'albertpamies.com',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Mejores fotógrafos de bodas en ${city}`,
  "description": `Los mejores fotógrafos de bodas en ${city} y Costa del Sol. Selección exclusiva de fotógrafos con premios internacionales.`,
  "url": `https://fotografosparabodas.es/${slug}/`,
  "numberOfItems": photographers.length,
  "itemListElement": photographers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.name,
      "description": p.bio,
      "url": p.web,
      "areaServed": { "@type": "City", "name": city },
      "knowsAbout": "Fotografía de bodas",
    }
  })),
};
---

<BaseLayout
  title="Fotógrafo de Bodas en Málaga — Albert Pamies · Costa del Sol 2026"
  description="Albert Pamies, el fotógrafo de bodas de referencia en Málaga y la Costa del Sol. MyWed #1 Mundial 2019 · Fearless Photographers USA. Selección exclusiva, contacto directo."
  canonical={`https://fotografosparabodas.es/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafo de Bodas\nen Málaga`}
      subtitle="El fotógrafo más reconocido de la Costa del Sol, disponible a través de nosotros. Contacto directo, sin intermediarios."
      ctaText="Ver fotógrafo"
      ctaHref="#fotografos"
      imageSrc="/images/photographers/albert/ap06.webp"
    />

    <!-- Intro local -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Málaga y Costa del Sol</p>
            <h2 class="section-title mb-6">Fotógrafo de bodas en Málaga:<br/>la luz mediterránea que lo cambia todo</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Málaga tiene una luz dorada única. Las fincas del interior, las playas de Nerja o los jardines de Ronda crean escenarios que los mejores fotógrafos saben aprovechar para crear imágenes atemporales.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              El fotógrafo de nuestra red en Málaga conoce cada recoveco de la provincia y lleva más de doce años trabajando con la luz directa del sur. Eso no se improvisa.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Fotógrafo listado', value: '1 · selección exclusiva' },
                { label: 'Premios internacionales', value: 'MyWed #1 · Fearless USA' },
                { label: 'Temporada alta', value: 'Abril – Octubre' },
                { label: 'Zonas populares', value: 'Marbella, Ronda, Nerja, Málaga' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Photographers -->
    <section id="fotografos" class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Selección exclusiva</p>
          <h2 class="section-title">El fotógrafo de referencia<br/>en Málaga y Costa del Sol</h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#6B5E58] max-w-lg mx-auto mt-4 text-sm leading-relaxed">
            Solo trabajamos con fotógrafos con premios internacionales contrastados y trayectoria verificada. En Málaga, solo Albert Pamies cumple nuestros criterios.
          </p>
        </div>

        <div class="space-y-8">
          {photographers.map((p, i) => <PhotographerProfile photographer={p} featured={i === 0} />)}
        </div>

        <div class="mt-12 bg-white border border-[#E8DDD3] rounded-sm p-8 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mb-3">
            Plaza disponible en Málaga
          </p>
          <p class="font-['Lato'] text-sm text-[#6B5E58] mb-6 max-w-md mx-auto">
            Solo aceptamos 2 fotógrafos por ciudad. Hay una plaza libre. Si tu portfolio y trayectoria encajan, es tuya.
          </p>
          <a href="/unete/" class="btn-gold">Solicitar mi plaza →</a>
        </div>
      </div>
    </section>

    <!-- SEO content -->
    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en Málaga?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            La Costa del Sol concentra una oferta enorme de fotógrafos de boda, especialmente en Marbella y Estepona por la demanda de bodas de destino. La diferencia de calidad entre los mejores y el resto es muy grande. Nuestra selección es intencionalmente pequeña: solo fotógrafos con premios internacionales reales, trayectoria demostrable y un estilo propio reconocible.
          </p>
          <p>
            Para bodas en temporada alta en la Costa del Sol (abril a octubre), los mejores fotógrafos cierran agenda con 12 meses o más de antelación. Si tenéis fecha confirmada, consultad disponibilidad cuanto antes.
          </p>
          <p>
            Albert Pamies trabaja en toda la provincia: Marbella, Ronda, Nerja, Estepona, Antequera y el centro de Málaga. Para bodas fuera de la Costa del Sol o en destinos europeos, contactadnos para confirmar disponibilidad y desplazamiento.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6">
        <p class="section-eyebrow mb-4">Fotógrafo bodas Málaga precio</p>
        <h2 class="section-title mb-4">¿Cuánto cuesta un fotógrafo<br/>de bodas en Málaga?</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 leading-relaxed">
          Málaga y la Costa del Sol tienen una demanda de bodas de destino muy alta, con parejas internacionales que elevan el nivel medio del mercado. Los fotógrafos de la zona están habituados a ese entorno y sus tarifas reflejan esa especialización. Estos son los rangos en 2026:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { rango: '1.000 – 1.800 €', nivel: 'Iniciación', desc: 'Fotógrafos con trayectoria inicial en la Costa del Sol. Buena opción para bodas con presupuesto ajustado si verificáis que conocen vuestro venue.' },
            { rango: '1.800 – 3.200 €', nivel: 'Intermedio', desc: 'Fotógrafos consolidados con experiencia en Marbella, Ronda y la Costa del Sol. El rango más habitual para bodas de nivel en la provincia.' },
            { rango: '3.200 – 6.000 €', nivel: 'Referencia', desc: 'Fotógrafos con premios internacionales habituados a bodas de destino en la Costa del Sol. Albert Pamies, clasificado #1 mundial en MyWed, trabaja en este segmento.' },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A] mb-1">{item.rango}</p>
              <p class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#1C1814] mb-3">{item.nivel}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
          Los fotógrafos de bodas en Málaga suelen cubrir toda la Costa del Sol sin coste adicional de desplazamiento. Para bodas en Ronda o fuera de la provincia, confirmadlo al pedir presupuesto. Si queréis ver disponibilidad para vuestra fecha, <a href="/#contacto" class="text-[#8B6A3A] underline">consultadnos sin compromiso</a>.
        </p>
      </div>
    </section>

    <FAQSection city={city} />

    <!-- Related -->
    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También en Andalucía</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-8">Más ciudades</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Córdoba', slug: 'cordoba' },
            { name: 'Granada', slug: 'granada' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">
              Fotógrafos en {c.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
