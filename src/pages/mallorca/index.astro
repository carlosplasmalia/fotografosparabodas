---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import ConciergeCitySection from '../../components/ConciergeCitySection.astro';
import FeaturedPhotographer from '../../components/FeaturedPhotographer.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';
import { getPhotographerByCity } from '../../data/photographers';

const city = 'Mallorca';
const slug = 'mallorca';
const featured = getPhotographerByCity(slug);
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Selección de fotógrafo de bodas en ${city}`,
  "url": `https://${site.domain}/${slug}/`,
  "serviceType": "Selección de fotógrafo de bodas",
  "areaServed": { "@type": "City", "name": city },
  "provider": {
    "@type": "Organization",
    "name": site.name,
    "url": `https://${site.domain}`
  }
};
---

<BaseLayout
  title='Fotógrafo de Bodas en Mallorca — Bodas de Destino · Selección 2026'
  description='Selección personalizada de fotógrafos de bodas en Mallorca y Baleares. Fincas de la Tramuntana, posesiones y calas. Español e inglés. Os encontramos el ideal. Gratis, 24 horas.'
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafo de Bodas\nen Mallorca`}
      subtitle='Las fincas de la Serra de Tramuntana, las posesiones señoriales y las calas turquesas. Mallorca es la capital española de la boda de destino.'
      ctaText="Consultar ahora"
      ctaHref="#fotografos"
      imageSrc="/images/hero-boda.webp"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Mallorca y Baleares</p>
            <h2 class="section-title mb-6">Fotógrafo de bodas en Mallorca:<br/>la isla de las bodas de destino</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Mallorca atrae cada año a cientos de parejas de toda Europa que eligen la isla para casarse: la luz mediterránea, las posesiones señoriales, los olivares de la Tramuntana y las calas hacen el resto. Eso ha creado una escena fotográfica de nivel internacional.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              Los fotógrafos mallorquines de referencia trabajan indistintamente en español, inglés y alemán, y dominan los códigos de la boda internacional: cronogramas distintos, ceremonias civiles al aire libre y sesiones al atardecer sobre el mar.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Tiempo de respuesta', value: 'menos de 24h' },
                { label: 'Temporada alta', value: 'Mayo – Octubre' },
                { label: 'Zonas populares', value: 'Tramuntana, posesiones, calas del sureste' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {featured && <FeaturedPhotographer photographer={featured} />}

    <ConciergeCitySection city={city} />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en Mallorca?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            En Mallorca conviven dos mercados: el local y el internacional de bodas de destino, con precios y códigos distintos. Si vuestra boda es internacional, buscad fotógrafos con experiencia demostrada en ese formato; si es local, hay excelentes profesionales a precios más contenidos.
          </p>
          <p>
            La logística insular importa: en temporada alta los mejores fotógrafos de la isla se llenan con mucha antelación, y traer a un fotógrafo de la península añade vuelos y noches de hotel. Reservad antes que casi cualquier otro proveedor.
          </p>
          <p>
            La luz de julio y agosto al mediodía es durísima; los buenos fotógrafos de la isla planifican las sesiones de pareja a última hora de la tarde. Un cronograma bien pensado con vuestro fotógrafo vale tanto como su cámara. Si no sabéis qué estilo buscáis, nuestra <a href="/blog/estilos-fotografia-de-boda-cual-elegir/" class="text-[#8B6A3A] underline">guía de estilos de fotografía de boda</a> puede ayudaros a definirlo antes de empezar a buscar.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6">
        <p class="section-eyebrow mb-4">Fotógrafo bodas Mallorca precio</p>
        <h2 class="section-title mb-4">¿Cuánto cuesta un fotógrafo<br/>de bodas en Mallorca?</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 leading-relaxed">
          Mallorca, como mercado de bodas de destino, tiene precios en la banda alta del país. Rangos habituales en 2026:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { rango: '1.200 – 1.800 €', nivel: 'Iniciación', desc: 'Fotógrafos emergentes locales. Buena opción para bodas íntimas y elopements fuera de temporada alta.' },
            { rango: '1.800 – 3.500 €', nivel: 'Intermedio', desc: 'Profesionales consolidados con experiencia en bodas locales e internacionales. El rango más habitual en la isla.' },
            { rango: '3.500 – 7.000 €', nivel: 'Referencia', desc: 'Fotógrafos de referencia del circuito internacional de bodas de destino, con publicaciones y clientela europea.' },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A] mb-1">{item.rango}</p>
              <p class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#1C1814] mb-3">{item.nivel}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
          Muchos fotógrafos de Mallorca cubren también Menorca e Ibiza, normalmente con suplemento de desplazamiento. Para bodas de mayo a octubre, reservad con 12-18 meses. <a href="/#contacto" class="text-[#8B6A3A] underline">Consultadnos sin compromiso</a>.
        </p>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También disponemos de fotógrafos en</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[{"name": "Barcelona", "slug": "barcelona"}, {"name": "Valencia", "slug": "valencia"}, {"name": "Tenerife", "slug": "tenerife"}].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">Fotógrafos en {c.name}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
