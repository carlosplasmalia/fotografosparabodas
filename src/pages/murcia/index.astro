---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import PhotographerProfile from '../../components/PhotographerProfile.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const city = 'Murcia';
const slug = 'murcia';
const avgPrice = '1.100€ – 1.900€';

const photographers = [
  {
    name: 'Pablo Herrero',
    city: 'Murcia',
    zone: 'Murcia · Cartagena · Costa Cálida',
    style: 'Fotojournalismo y fine art',
    styleDesc: 'Historias reales sin poses, con acabados cinematográficos',
    price: 'desde 1.300€',
    bio: 'Pablo Herrero trabaja bodas en Murcia y la Costa Cálida desde 2015. Su enfoque periodístico captura los momentos tal como ocurren, sin interrumpir el flujo del día. Especialista en bodas al aire libre y en las masías del interior murciano.',
    avatar: '/images/cities/murcia.jpg',
    portfolio: [
      { src: '/images/portfolio/malaga-1.jpg', alt: 'Boda en Murcia — Pablo Herrero' },
      { src: '/images/portfolio/malaga-3.jpg', alt: 'Fotografía boda Cartagena — Pablo Herrero' },
      { src: '/images/cities/murcia.jpg',      alt: 'Bodas Costa Cálida — Pablo Herrero' },
    ],
    badge: 'Verificado',
    yearsExp: 9,
    awards: ['Fearless Photographers Associate'],
    photoCredit: 'Pablo Herrero',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Mejores fotógrafos de bodas en ${city}`,
  "description": `Directorio de los mejores fotógrafos de bodas en ${city} y Costa Cálida.`,
  "url": `https://${site.domain}/${slug}/`,
  "numberOfItems": photographers.length,
  "itemListElement": photographers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.name,
      "description": p.bio,
      "areaServed": { "@type": "City", "name": city },
      "priceRange": p.price,
      "knowsAbout": "Fotografía de bodas",
    }
  })),
};
---

<BaseLayout
  title="Fotógrafos de Bodas en Murcia — Directorio verificado 2026"
  description="Los mejores fotógrafos de bodas en Murcia y Costa Cálida. Perfiles verificados, portfolios reales. Precio medio: 1.100€ – 1.900€. Consulta disponibilidad gratis."
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafos de Bodas\nen Murcia`}
      subtitle="Fotógrafos verificados para bodas en Murcia, Cartagena y Costa Cálida. Contacta sin compromiso."
      ctaText="Ver fotógrafos"
      ctaHref="#fotografos"
      imageSrc="/images/cities/murcia.jpg"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Murcia y Costa Cálida</p>
            <h2 class="section-title mb-6">Luz levantina<br/>y bodas con carácter</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Murcia tiene una de las tasas de sol más altas de Europa. Esa luz clara y directa, que puede ser complicada en verano, es una ventaja real cuando el fotógrafo sabe trabajar con ella. Las bodas en Murcia suelen celebrarse en fincas rurales, haciendas o en la costa de Cartagena.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              El precio es uno de los más competitivos del sureste peninsular, sin renunciar a calidad. Un argumento a tener en cuenta si tenéis el presupuesto ajustado.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Precio medio', value: avgPrice },
                { label: 'Fotógrafos verificados', value: `${photographers.length} activo` },
                { label: 'Temporada alta', value: 'Abril – Octubre' },
                { label: 'Zonas populares', value: 'Cartagena, Lorca, Mazarrón, Sierra Espuña' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="fotografos" class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Directorio exclusivo</p>
          <h2 class="section-title">Fotógrafo de boda<br/>de referencia en Murcia</h2>
          <span class="gold-divider"></span>
        </div>

        <div class="space-y-8">
          {photographers.map((p, i) => <PhotographerProfile photographer={p} featured={i === 0} />)}
        </div>

        <div class="mt-8 border-2 border-dashed border-[#E8DDD3] rounded-sm p-10 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#6B5E58] mb-3">Plaza disponible en Murcia</p>
          <p class="font-['Lato'] text-sm text-[#9A8880] max-w-sm mx-auto mb-6 leading-relaxed">
            Estamos seleccionando un segundo fotógrafo para cubrir toda la región. ¿Trabajas bodas en Murcia?
          </p>
          <a href="/unete/" class="btn-outline text-sm px-6 py-3">Solicitar plaza →</a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cuánto cuesta un fotógrafo de bodas en Murcia?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            En Murcia, el precio de un fotógrafo de bodas en 2026 es de los más accesibles del sureste: entre <strong class="text-[#1C1814]">1.100€ y 1.900€</strong>. Para bodas en Cartagena o en la costa, los precios tienden a ser ligeramente superiores por la demanda de bodas de destino.
          </p>
          <p>
            Un reportaje completo incluye preparativos, ceremonia y banquete, con entrega de 400-600 fotos editadas. La temporada alta va de abril a octubre, con especial demanda en los meses de mayo, junio y septiembre.
          </p>
          <p>
            Reservad con 8-12 meses de antelación si tenéis una fecha concreta en mente, especialmente para fines de semana de primavera y otoño.
          </p>
        </div>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También en el sureste</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-8">Más ciudades</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Alicante', slug: 'alicante' },
            { name: 'Málaga', slug: 'malaga' },
            { name: 'Granada', slug: 'granada' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">
              Fotógrafos en {c.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
