---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import ConciergeCitySection from '../../components/ConciergeCitySection.astro';
import FeaturedPhotographer from '../../components/FeaturedPhotographer.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';
import { getPhotographerByCity } from '../../data/photographers';

const city = 'Pamplona';
const slug = 'pamplona';
const featured = getPhotographerByCity(slug);
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Selección de fotógrafo de bodas en ${city}`,
  "url": `https://${site.domain}/${slug}/`,
  "serviceType": "Selección de fotógrafo de bodas",
  "areaServed": { "@type": "City", "name": city },
  "provider": {
    "@type": "Organization",
    "name": site.name,
    "url": `https://${site.domain}`
  }
};
---

<BaseLayout
  title='Fotógrafo de Bodas en Pamplona — Navarra al completo · Selección 2026'
  description='Selección personalizada de fotógrafos de bodas en Pamplona y Navarra. Del Pirineo a las Bardenas, palacios y fincas de la Zona Media. Os encontramos el ideal. Gratis, 24 horas.'
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafo de Bodas\nen Pamplona`}
      subtitle='Del Pirineo a las Bardenas Reales, con los palacios y señoríos de la Zona Media entre medias. Navarra es un plató natural y os encontramos quien sabe usarlo.'
      ctaText="Consultar ahora"
      ctaHref="#fotografos"
      imageSrc="/images/hero-boda.webp"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Pamplona y Navarra</p>
            <h2 class="section-title mb-6">Fotógrafo de bodas en Pamplona:<br/>de la montaña al desierto</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Navarra concentra en pocos kilómetros una variedad de paisajes única: los bosques del Pirineo y el Irati, los viñedos de la Ribera, el desierto de las Bardenas Reales y una Zona Media llena de palacios, señoríos y bodegas para celebrar.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              Pamplona funciona como centro de todo ese mapa. Los fotógrafos navarros están acostumbrados a moverse entre escenarios radicalmente distintos, y esa versatilidad se nota en los reportajes.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Tiempo de respuesta', value: 'menos de 24h' },
                { label: 'Temporada alta', value: 'Mayo – Octubre' },
                { label: 'Zonas populares', value: 'Zona Media, Pirineo, Bardenas' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {featured && <FeaturedPhotographer photographer={featured} />}

    <ConciergeCitySection city={city} />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en Pamplona?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            En Navarra el venue condiciona mucho la elección del fotógrafo. Una boda en un palacio de la Zona Media pide un registro distinto que una celebración en una borda del Pirineo o una sesión al atardecer en las Bardenas. Buscad reportajes en entornos parecidos al vuestro.
          </p>
          <p>
            El clima navarro es cambiante: un buen fotógrafo local sabe convertir un día gris del norte en un reportaje con atmósfera en lugar de lamentarlo. Preguntad cómo resuelve la lluvia; la respuesta dice mucho del oficio de cada profesional.
          </p>
          <p>
            La escena local es más pequeña que la de Madrid o Barcelona, pero tiene profesionales de nivel con cientos de bodas a la espalda y precios más razonables que en las grandes capitales. Si no sabéis qué estilo buscáis, nuestra <a href="/blog/estilos-fotografia-de-boda-cual-elegir/" class="text-[#8B6A3A] underline">guía de estilos de fotografía de boda</a> puede ayudaros a definirlo antes de empezar a buscar.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6">
        <p class="section-eyebrow mb-4">Fotógrafo bodas Pamplona precio</p>
        <h2 class="section-title mb-4">¿Cuánto cuesta un fotógrafo<br/>de bodas en Pamplona?</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 leading-relaxed">
          Los precios en Navarra son sensiblemente más contenidos que en Madrid o Barcelona. Rangos habituales en 2026:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { rango: '900 – 1.400 €', nivel: 'Iniciación', desc: 'Fotógrafos emergentes de la zona. Revisar bodas completas y comprobar cómo resuelven interiores con poca luz.' },
            { rango: '1.400 – 2.400 €', nivel: 'Intermedio', desc: 'Profesionales consolidados con años de experiencia en los venues navarros. El rango más habitual para bodas de nivel.' },
            { rango: '2.400 – 4.500 €', nivel: 'Referencia', desc: 'Los fotógrafos de referencia de la comunidad, con cientos de bodas y estilo propio reconocible.' },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A] mb-1">{item.rango}</p>
              <p class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#1C1814] mb-3">{item.nivel}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
          Los fotógrafos de Pamplona suelen cubrir toda Navarra sin coste adicional y muchos trabajan también La Rioja, Gipuzkoa y Aragón. <a href="/#contacto" class="text-[#8B6A3A] underline">Consultadnos sin compromiso</a>.
        </p>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También disponemos de fotógrafos en</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[{"name": "Logroño", "slug": "logrono"}, {"name": "Bilbao", "slug": "bilbao"}, {"name": "Zaragoza", "slug": "zaragoza"}].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">Fotógrafos en {c.name}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
