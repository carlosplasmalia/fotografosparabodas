---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import ConciergeCitySection from '../../components/ConciergeCitySection.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const city = 'San Sebastián';
const slug = 'san-sebastian';
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Selección de fotógrafo de bodas en ${city}`,
  "url": `https://${site.domain}/${slug}/`,
  "serviceType": "Selección de fotógrafo de bodas",
  "areaServed": { "@type": "City", "name": city },
  "provider": {
    "@type": "Organization",
    "name": site.name,
    "url": `https://${site.domain}`
  }
};
---

<BaseLayout
  title="Fotógrafo de Bodas en San Sebastián — Donostia · Selección 2026"
  description="Selección personalizada de fotógrafos de bodas en San Sebastián y Gipuzkoa. Caseríos, txakolís y bodas de nivel en Donostia. Gratis, respuesta en 24 horas."
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafo de Bodas\nen San Sebastián`}
      subtitle="Caseríos, txakolís, La Concha y bodas de nivel en Donostia y toda Gipuzkoa. Os encontramos el fotógrafo que conoce el norte."
      ctaText="Consultar ahora"
      ctaHref="#fotografos"
      imageSrc="/images/cities/san-sebastian.webp"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Donostia y Gipuzkoa</p>
            <h2 class="section-title mb-6">Fotógrafos de bodas en San Sebastián<br/>y Donostia: la perla del norte</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              San Sebastián tiene una concentración de talento fotográfico fuera de lo normal para su tamaño. La ciudad tiene una sensibilidad estética propia, influida por la gastronomía y la cultura vasca, que se traslada al trabajo de sus mejores fotógrafos.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              Las bodas en Gipuzkoa suelen ser de alto nivel: venues exclusivos, catering de primer nivel, invitados exigentes. Los fotógrafos que trabajamos en esta zona están habituados a ese entorno.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Tiempo de respuesta', value: 'menos de 24h' },
                { label: 'Temporada alta', value: 'Junio – Septiembre' },
                { label: 'Zonas populares', value: 'La Concha, caseríos, Zarautz' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <ConciergeCitySection city={city} />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en San Sebastián?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            San Sebastián tiene una concentración de talento fotográfico excepcional para ser una ciudad de su tamaño. Las bodas en el País Vasco suelen tener un nivel de producción muy cuidado y los fotógrafos de la zona están acostumbrados a trabajar en palacios, caseríos históricos, restaurantes con estrella y acantilados sobre el Cantábrico. La luz verde y tamizada del norte, tan distinta a la del sur, da a las fotos de bodas en Donostia un carácter muy reconocible.
          </p>
          <p>
            Para bodas en los venues más demandados de Gipuzkoa, los mejores fotógrafos tienen lista de espera de 18 a 24 meses. Si tenéis fecha confirmada, no esperéis. Los fotógrafos de nuestra red en San Sebastián incluyen desplazamientos por toda Gipuzkoa sin coste adicional. Para bodas en Álava o Vizcaya, consultad si hay suplemento.
          </p>
          <p>
            Si no tenéis claro qué estilo fotográfico buscáis para vuestra boda, nuestra <a href="/blog/estilos-fotografia-de-boda-cual-elegir/" class="text-[#8B6A3A] underline">guía de estilos de fotografía de boda</a> explica las diferencias entre documental, romántico y editorial con ejemplos reales. Es un buen punto de partida antes de hablar con ningún fotógrafo.
          </p>
        </div>
      </div>
    </section>

    <!-- Precio fotógrafo bodas San Sebastián -->
    <section class="py-16 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6">
        <p class="section-eyebrow mb-4">Fotógrafo bodas San Sebastián precio</p>
        <h2 class="section-title mb-4">¿Cuánto cuesta un fotógrafo<br/>de bodas en Donostia?</h2>
        <span class="gold-divider"></span>
        <p class="font-['Lato'] text-[#6B5E58] mt-6 mb-8 leading-relaxed">
          Los fotógrafos de bodas en San Sebastián y Donostia trabajan habitualmente en venues de alto nivel: palacios, caseríos con historia, restaurantes con estrella Michelin y fincas con vistas al Cantábrico. Eso se refleja en el precio, que suele ser ligeramente superior a la media nacional. Estos son los rangos del mercado en Gipuzkoa en 2026:
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
          {[
            { rango: '1.400 – 2.200 €', nivel: 'Iniciación', desc: 'Fotógrafos con menos de 3 años de experiencia en bodas en el País Vasco. Disponibles para bodas con presupuesto ajustado.' },
            { rango: '2.200 – 3.800 €', nivel: 'Intermedio', desc: 'Fotógrafos con trayectoria consolidada en Donostia y Gipuzkoa. El rango más habitual para bodas de nivel medio-alto.' },
            { rango: '3.800 – 6.500 €', nivel: 'Referencia', desc: 'Fotógrafos con premios internacionales y agenda muy limitada. Habituales en los mejores venues de la Costa Vasca.' },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-6">
              <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#8B6A3A] mb-1">{item.rango}</p>
              <p class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#1C1814] mb-3">{item.nivel}</p>
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">
          Los fotógrafos de bodas en San Sebastián y Donostia suelen cubrir toda Gipuzkoa sin coste adicional de desplazamiento. Para bodas en Álava o Vizcaya consultad si hay suplemento. Si queréis saber si el presupuesto de nuestra red encaja con el vuestro, <a href="/#contacto" class="text-[#8B6A3A] underline">consultadnos sin compromiso</a>.
        </p>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También disponemos de fotógrafos en</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Bilbao', slug: 'bilbao' },
            { name: 'Zaragoza', slug: 'zaragoza' },
            { name: 'Madrid', slug: 'madrid' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">Fotógrafos en {c.name}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
