---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { site } from '../../config/site';
---

<BaseLayout
  title="Colabora con Nosotros — Red de Fotógrafos de Bodas"
  description="¿Eres fotógrafo de bodas? Únete a nuestra red de colaboradores. Te enviamos parejas pre-cualificadas. Sin cuota mensual, solo pagas si cierras la boda."
  canonical={`https://${site.domain}/unete/`}
  noindex={false}
>
  <SiteHeader />
  <main class="pt-16">

    <!-- Hero -->
    <section class="bg-[#1C1814] py-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] mb-6">
          Para fotógrafos de bodas
        </p>
        <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-semibold text-white leading-tight mb-6">
          Parejas pre-cualificadas,<br/>
          <em class="text-[#B89060] not-italic">listas para reservar.</em>
        </h1>
        <p class="font-['Lato'] text-[#9A8880] text-lg max-w-xl mx-auto leading-relaxed mb-10">
          Somos un servicio de selección personalizada para novios. Cuando una pareja nos pide fotógrafo para su ciudad, os la enviamos directamente. Sin cuota mensual. Solo pagas si se confirma la boda.
        </p>
        <a href="#solicitar" class="btn-gold text-base px-10 py-4">
          Quiero colaborar →
        </a>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section class="py-20 bg-[#FAF7F2]">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">El modelo</p>
          <h2 class="section-title">Sin riesgo.<br/>Sin cuota fija.</h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#6B5E58] mt-6 max-w-lg mx-auto text-sm leading-relaxed">
            No cobramos por estar en la red. Solo cobramos una comisión cuando vuestra relación con la pareja se convierte en una boda reservada.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              num: '01',
              title: 'Una pareja nos contacta',
              body: 'Alguien busca fotógrafo en vuestra ciudad o zona. Nos envía fecha, venue y estilo. Nosotros cualificamos la consulta antes de pasárosla.',
            },
            {
              num: '02',
              title: 'Os la presentamos a vosotros',
              body: 'Si encajáis con el perfil que buscan, os enviamos la consulta directamente. La pareja va con vuestro nombre, portfolio y contexto ya preparado.',
            },
            {
              num: '03',
              title: 'Si se confirma, pagáis comisión',
              body: 'Si la pareja reserva con vosotros, nos avisáis y liquidamos una comisión acordada. Nada de cuotas si el mes está flojo. Cero riesgo.',
            },
          ].map(item => (
            <div class="bg-white border border-[#E8DDD3] rounded-sm p-8">
              <div class="w-12 h-12 rounded-full border border-[#B89060] flex items-center justify-center mb-6">
                <span class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#B89060]">{item.num}</span>
              </div>
              <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mb-3">{item.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Qué incluye -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div>
            <p class="section-eyebrow mb-4">Lo que obtenéis</p>
            <h2 class="section-title mb-6">Más que una<br/>referencia</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-6">
              Los fotógrafos de nuestra red tienen un perfil editorial propio en la web. Una página diseñada para convertir, con portfolio real, texto SEO y botón de contacto directo. La mantenemos nosotros.
            </p>
            <ul class="space-y-4">
              {[
                'Página de perfil completa con portfolio',
                'Texto editorial escrito para posicionar vuestro nombre',
                'Botón WhatsApp con mensaje pre-cargado',
                'Visibilidad desde las páginas de ciudad',
                'Consultas pre-cualificadas: ya saben tu precio aproximado',
                'Sin cuota mensual — solo comisión por boda cerrada',
              ].map((item) => (
                <li class="flex items-start gap-4">
                  <span class="text-[#B89060] font-bold mt-0.5">✓</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814] leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Comisión -->
          <div class="bg-[#1C1814] rounded-sm p-8 text-white">
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#B89060] mb-6">Condiciones</p>
            <div class="mb-8">
              <div class="flex items-baseline gap-2 mb-2">
                <span class="font-['Cormorant_Garamond'] text-5xl font-semibold text-white">10%</span>
                <span class="font-['Lato'] text-[#9A8880] text-sm">por boda cerrada</span>
              </div>
              <p class="font-['Lato'] text-[#9A8880] text-sm leading-relaxed">
                Sobre el presupuesto acordado con la pareja. Sin mínimos, sin cuota, sin permanencia.
              </p>
            </div>
            <ul class="space-y-3 mb-8">
              {[
                'Sin cuota mensual ni de entrada',
                'Pagas solo si cierras la boda',
                'Perfil editorial incluido sin coste',
                'Comisión acordada antes de cada referencia',
                'Liquidación sencilla por transferencia',
                'Podéis salir cuando queráis',
              ].map(item => (
                <li class="flex items-center gap-3 font-['Lato'] text-sm text-[#C4A5A0]">
                  <span class="text-[#B89060]">✓</span>
                  {item}
                </li>
              ))}
            </ul>
            <div class="border-t border-[#2E2520] pt-6">
              <p class="font-['Lato'] text-xs text-[#6B5E58] leading-relaxed">
                La comisión exacta se pacta con cada fotógrafo según ciudad y perfil. Hablamos sin compromiso.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Proceso de selección -->
    <section class="py-20 bg-[#FAF7F2]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">Cómo empezar</p>
        <h2 class="section-title mb-6">Cuatro pasos<br/>y estáis dentro</h2>
        <span class="gold-divider mb-12"></span>
        <div class="space-y-6 text-left">
          {[
            { n: '1', t: 'Mandadnos vuestra web o Instagram', d: 'Revisamos el portfolio. Esto no es un directorio masivo: solo trabajamos con fotógrafos cuyo nivel justifica nuestra recomendación a las parejas.' },
            { n: '2', t: 'Revisión en 48 horas', d: 'Si el trabajo encaja, os lo decimos rápido. Si hay algún perfil mejor posicionado en vuestra ciudad, también os lo decimos con honestidad.' },
            { n: '3', t: 'Acordamos las condiciones', d: 'Una conversación corta para pactar la comisión, el tipo de parejas en las que pensamos y cómo gestionamos los leads.' },
            { n: '4', t: 'Publicamos vuestro perfil', d: 'Montamos la página, escribimos el texto editorial y quedáis visibles desde las páginas de ciudad y los resultados de búsqueda.' },
          ].map(s => (
            <div class="flex items-start gap-6 bg-white border border-[#E8DDD3] rounded-sm p-6">
              <div class="w-10 h-10 rounded-full bg-[#F2E8D5] border border-[#B89060]/40 flex items-center justify-center shrink-0 font-['Cormorant_Garamond'] text-lg font-semibold text-[#B89060]">
                {s.n}
              </div>
              <div>
                <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-1">{s.t}</h3>
                <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Formulario de contacto -->
    <section id="solicitar" class="py-20 bg-white">
      <div class="max-w-xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="section-eyebrow mb-4">Contacto inicial</p>
          <h2 class="section-title">Hablamos sin compromiso</h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#6B5E58] mt-6 text-sm leading-relaxed">
            Rellena el formulario o escríbenos por WhatsApp. Te respondemos en 48 horas.
          </p>
        </div>

        <div class="mb-6 text-center">
          <a
            href="https://wa.me/34625677487?text=Hola%2C%20soy%20fotógrafo%20de%20bodas%20y%20me%20interesa%20colaborar%20con%20vosotros"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold inline-flex items-center gap-2 px-8 py-3"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Escribir por WhatsApp
          </a>
        </div>

        <div class="text-center mb-6">
          <span class="font-['Lato'] text-sm text-[#9A8880]">— o usa el formulario —</span>
        </div>

        <form
          action="https://formspree.io/f/XXXXXXXX"
          method="POST"
          class="space-y-4 bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-8"
        >
          <input type="hidden" name="_subject" value="Nueva solicitud colaboración fotógrafo — fotografosparabodas.es" />

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Nombre</label>
            <input type="text" name="nombre" required placeholder="Tu nombre o nombre de estudio"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#B89060] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Email</label>
            <input type="email" name="email" required placeholder="tu@email.com"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#B89060] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Ciudad o zona donde operas</label>
            <input type="text" name="ciudad" required placeholder="Málaga, Costa del Sol..."
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#B89060] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Tu web o Instagram</label>
            <input type="text" name="portfolio" required placeholder="https://tuportfolio.com o @instagram"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#B89060] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">¿Algo que quieras contarnos?</label>
            <textarea name="mensaje" rows="3" placeholder="Bodas por las que estáis más especializados, zonas, precio medio..."
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#B89060] transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="btn-gold w-full py-4 text-base">
            Enviar solicitud →
          </button>
          <p class="font-['Lato'] text-xs text-[#9A8880] text-center">
            Sin compromiso. Revisamos y respondemos en 48 horas.
          </p>
        </form>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>
