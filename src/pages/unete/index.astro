---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { site } from '../../config/site';
---

<BaseLayout
  title="Colabora con Nosotros — Portal de Referencia para Fotógrafos Pro"
  description="Solo trabajamos con fotógrafos de bodas de alto nivel. Si tu trabajo es excepcional y buscas parejas que valoran la calidad, hablamos."
  canonical={`https://${site.domain}/unete/`}
  noindex={false}
>
  <SiteHeader />
  <main class="pt-16">

    <!-- Hero -->
    <section class="bg-[#1C1814] py-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] mb-6">
          Para fotógrafos de bodas profesionales
        </p>
        <h1 class="font-['Cormorant_Garamond'] text-5xl md:text-6xl font-semibold text-white leading-tight mb-6">
          El portal de referencia<br/>
          <em class="text-[#8B6A3A] not-italic">para fotógrafos de alto nivel.</em>
        </h1>
        <p class="font-['Lato'] text-[#9A8880] text-lg max-w-xl mx-auto leading-relaxed mb-10">
          No somos un directorio masivo. Somos un portal de selección exclusiva donde solo tienen cabida los fotógrafos cuyo trabajo habla por sí solo. Parejas exigentes buscan exactamente eso.
        </p>
        <a href="#solicitar" class="btn-gold text-base px-10 py-4">
          Solicitar acceso →
        </a>
      </div>
    </section>

    <!-- A quién va dirigido -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Criterio de selección</p>
          <h2 class="section-title">Solo los mejores.<br/>Sin excepciones.</h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#6B5E58] mt-6 max-w-lg mx-auto text-sm leading-relaxed">
            Revisamos cada solicitud a mano. Aceptamos únicamente fotógrafos con una trayectoria real, un estilo propio reconocible y el nivel que esperan nuestras parejas.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {[
            {
              title: 'Trayectoria contrastada',
              body: 'Años de experiencia y un portfolio que lo demuestra. No hace falta tener premios internacionales, pero sí un trabajo que resistiría la comparación con los mejores.',
            },
            {
              title: 'Estilo propio y coherente',
              body: 'Buscamos fotógrafos con una firma visual reconocible. Que alguien vea veinte fotos y sepa que son tuyas. Sin eso, no hay diferenciación real.',
            },
            {
              title: 'Orientados a bodas de calidad',
              body: 'Nuestras parejas valoran el trabajo bien hecho y no comparan por precio. Si trabajas en ese segmento, o quieres hacerlo, encajas aquí.',
            },
          ].map(item => (
            <div class="bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-8">
              <div class="w-10 h-10 rounded-full border border-[#8B6A3A] flex items-center justify-center mb-6">
                <span class="text-[#8B6A3A] text-lg">★</span>
              </div>
              <h3 class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#1C1814] mb-3">{item.title}</h3>
              <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Lo que incluye estar en la red -->
    <section class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div>
            <p class="section-eyebrow mb-4">Lo que obtenéis</p>
            <h2 class="section-title mb-6">Visibilidad que<br/>trabaja para vosotros</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-6">
              Cada fotógrafo de nuestra red tiene una página de perfil editorial propia, diseñada para convertir. Con portfolio real, texto SEO posicionado con vuestro nombre y zona, y botón de contacto directo. La mantenemos nosotros.
            </p>
            <ul class="space-y-4">
              {[
                'Página de perfil editorial con portfolio real',
                'Texto SEO posicionado por nombre y ciudad',
                'Visibilidad desde las páginas de ciudad de toda España',
                'Parejas que ya conocen vuestro trabajo antes de contactar',
                'Sin directorio masivo — posición destacada garantizada',
                'Condiciones acordadas directamente, sin letra pequeña',
              ].map((item) => (
                <li class="flex items-start gap-4">
                  <span class="text-[#8B6A3A] font-bold mt-0.5">✓</span>
                  <span class="font-['Lato'] text-sm text-[#1C1814] leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-[#1C1814] rounded-sm p-8 text-white">
            <p class="font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#8B6A3A] mb-8">Por qué aquí</p>
            <ul class="space-y-6">
              {[
                {
                  t: 'Selección, no masificación',
                  d: 'Máximo dos fotógrafos por ciudad. Vuestro perfil no compite con cien más en la misma página.',
                },
                {
                  t: 'Parejas de alto nivel',
                  d: 'Trabajamos para que os lleguen parejas que valoran la fotografía como inversión, no como gasto.',
                },
                {
                  t: 'Posicionamiento a largo plazo',
                  d: 'Vuestro perfil posiciona en Google por vuestro nombre y ciudad. Un activo que crece con el tiempo.',
                },
              ].map(item => (
                <li class="border-b border-[#2E2520] pb-6 last:border-0 last:pb-0">
                  <p class="font-['Cormorant_Garamond'] text-xl font-semibold text-white mb-1">{item.t}</p>
                  <p class="font-['Lato'] text-sm text-[#9A8880] leading-relaxed">{item.d}</p>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Proceso -->
    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">Cómo empezar</p>
        <h2 class="section-title mb-6">El proceso,<br/>sin rodeos</h2>
        <span class="gold-divider mb-12"></span>
        <div class="space-y-6 text-left">
          {[
            { n: '1', t: 'Mandadnos vuestro trabajo', d: 'Web o Instagram. Revisamos el portfolio antes de contestar. Si el nivel no encaja, os lo decimos con honestidad — preferimos eso a haceros perder el tiempo.' },
            { n: '2', t: 'Revisión en 48 horas', d: 'Evaluamos trayectoria, estilo y coherencia. Si encajáis en nuestra selección, os contactamos para hablar.' },
            { n: '3', t: 'Una conversación directa', d: 'Hablamos de cómo funciona la colaboración, qué tipo de parejas buscamos para vosotros y cómo se gestiona todo. Sin letra pequeña.' },
            { n: '4', t: 'Publicamos vuestro perfil', d: 'Creamos la página editorial, escribimos el texto SEO y quedáis visibles desde las páginas de ciudad. Vosotros, a fotografiar.' },
          ].map(s => (
            <div class="flex items-start gap-6 bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-6">
              <div class="w-10 h-10 rounded-full bg-white border border-[#8B6A3A]/40 flex items-center justify-center shrink-0 font-['Cormorant_Garamond'] text-lg font-semibold text-[#8B6A3A]">
                {s.n}
              </div>
              <div>
                <h3 class="font-['Cormorant_Garamond'] text-xl font-semibold text-[#1C1814] mb-1">{s.t}</h3>
                <p class="font-['Lato'] text-sm text-[#6B5E58] leading-relaxed">{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Contacto -->
    <section id="solicitar" class="py-20 bg-[#1C1814]">
      <div class="max-w-xl mx-auto px-6">
        <div class="text-center mb-10">
          <p class="section-eyebrow text-[#8B6A3A] mb-4">Solicitar acceso</p>
          <h2 class="font-['Cormorant_Garamond'] text-4xl font-semibold text-white mb-4">
            Hablamos sin compromiso
          </h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#9A8880] mt-6 text-sm leading-relaxed">
            Envíanos tu portfolio. Respondemos en 48 horas. Si no encajas ahora, te decimos por qué — y eso también tiene valor.
          </p>
        </div>

        <div class="mb-6 text-center">
          <a
            href={`https://wa.me/${site.whatsapp}?text=Hola%2C%20soy%20fotógrafo%20de%20bodas%20y%20me%20interesa%20colaborar%20con%20vosotros`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-gold inline-flex items-center gap-2 px-8 py-3"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            Escribir por WhatsApp
          </a>
        </div>

        <div class="text-center mb-6">
          <span class="font-['Lato'] text-sm text-[#6B5E58]">— o usa el formulario —</span>
        </div>

        <form
          action="https://formspree.io/f/XXXXXXXX"
          method="POST"
          class="space-y-4 bg-[#FAF7F2] border border-[#E8DDD3] rounded-sm p-8"
        >
          <input type="hidden" name="_subject" value="Solicitud colaboración fotógrafo — fotografosparabodas.es" />

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Nombre o estudio</label>
            <input type="text" name="nombre" required placeholder="Tu nombre o nombre de estudio"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#8B6A3A] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Email</label>
            <input type="email" name="email" required placeholder="tu@email.com"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#8B6A3A] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Ciudad o zona donde operas</label>
            <input type="text" name="ciudad" required placeholder="Málaga, Costa del Sol, España..."
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#8B6A3A] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">Tu web o Instagram</label>
            <input type="text" name="portfolio" required placeholder="https://tuportfolio.com o @instagram"
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#8B6A3A] transition-colors" />
          </div>

          <div>
            <label class="block font-['Lato'] text-xs font-bold tracking-widest uppercase text-[#6B5E58] mb-2">¿Algo que quieras contarnos?</label>
            <textarea name="mensaje" rows="3" placeholder="Especialización, zonas, tipo de bodas que más fotografías..."
              class="w-full border border-[#E8DDD3] rounded-sm px-4 py-3 font-['Lato'] text-sm text-[#1C1814] bg-white focus:outline-none focus:border-[#8B6A3A] transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="btn-gold w-full py-4 text-base">
            Enviar solicitud →
          </button>
          <p class="font-['Lato'] text-xs text-[#9A8880] text-center">
            Revisamos cada solicitud a mano. Respuesta en 48 horas.
          </p>
        </form>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>
