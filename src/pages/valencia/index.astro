---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import ConciergeCitySection from '../../components/ConciergeCitySection.astro';
import FeaturedPhotographer from '../../components/FeaturedPhotographer.astro';
import { getPhotographerByCity } from '../../data/photographers';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const city = 'Valencia';
const slug = 'valencia';
const featured = getPhotographerByCity(slug);
const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": `Selección de fotógrafo de bodas en ${city}`,
  "url": `https://${site.domain}/${slug}/`,
  "serviceType": "Selección de fotógrafo de bodas",
  "areaServed": { "@type": "City", "name": city },
  "provider": {
    "@type": "Organization",
    "name": site.name,
    "url": `https://${site.domain}`
  }
};
---

<BaseLayout
  title="Fotógrafo de Bodas en Valencia — Mediterráneo, Huerta y Luz Dorada · 2026"
  description="Selección personalizada de fotógrafos de bodas en Valencia. Masías de la huerta, playas y la luz mediterránea del Levante. Os encontramos el ideal. Gratis, 24 horas."
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafo de Bodas\nen Valencia`}
      subtitle="Masías de la huerta, playas del Mediterráneo y la Ciudad de las Artes y las Ciencias. Os encontramos el fotógrafo que sabe trabajar la luz levantina."
      ctaText="Consultar ahora"
      ctaHref="#fotografos"
      imageSrc="/images/cities/valencia.webp"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Valencia y provincia</p>
            <h2 class="section-title mb-6">Fotógrafo de bodas en Valencia:<br/>luz mediterránea todo el año</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Valencia tiene una de las luces más constantes de España: el sol del Mediterráneo que llega limpio desde el mar y que en primavera y otoño crea una calidez dorada difícil de imitar en cualquier otro punto de la península. Las masías de la huerta valenciana, con sus naranjos y arrozales al fondo, ofrecen escenarios que no existen en ningún otro sitio.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              La Ciudad de las Artes, el barrio del Carmen, las playas de la Malvarrosa y las bodegas modernistas de la provincia concentran algunos de los venues de boda más originales del país. Fotógrafos de bodas en Valencia con carrera larga conocen todos esos espacios de memoria.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Tiempo de respuesta', value: 'menos de 24h' },
                { label: 'Temporada alta', value: 'Abril – Junio, Sept – Oct' },
                { label: 'Zonas populares', value: 'Huerta, Costa, Ciudad de las Artes' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {featured && <FeaturedPhotographer photographer={featured} />}

    <ConciergeCitySection city={city} />

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cómo elegir fotógrafo de bodas en Valencia?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            Valencia tiene una escena fotográfica muy activa, con fotógrafos de bodas que llevan años trabajando tanto para parejas locales como para bodas de destino de parejas europeas que eligen el Mediterráneo. Esa doble experiencia se nota: saben gestionar idiomas, coordinarse con wedding planners internacionales y trabajar en venues que van desde la masía rústica hasta el espacio de diseño contemporáneo.
          </p>
          <p>
            La temporada de bodas en Valencia es larga gracias al clima. Incluso en invierno, la luz suave de los días despejados produce resultados muy buenos para fotos de exterior. Eso significa que los fotógrafos más demandados trabajan casi todo el año y sus agendas para primavera se llenan a partir de otoño del año anterior.
          </p>
          <p>
            Al buscar fotógrafo, preguntad por su experiencia en vuestro tipo de venue concreto. Un fotógrafo especializado en masías de la huerta puede no tener el mismo ojo para una boda en un espacio urbano del Carmen, y viceversa. Si aún no tenéis claro qué estilo os representa, nuestra <a href="/blog/cuanto-cuesta-fotografo-boda-espana-2026/" class="text-[#8B6A3A] underline">guía de precios de fotografía de boda</a> también puede ayudaros a orientar el presupuesto antes de contactar.
          </p>
        </div>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">También disponemos de fotógrafos en</p>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Alicante', slug: 'alicante' },
            { name: 'Madrid', slug: 'madrid' },
            { name: 'Murcia', slug: 'murcia' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">Fotógrafos en {c.name}</a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
