---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Hero from '../../components/Hero.astro';
import PhotographerProfile from '../../components/PhotographerProfile.astro';
import FAQSection from '../../components/FAQSection.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { site } from '../../config/site';

const city = 'Zaragoza';
const slug = 'zaragoza';
const avgPrice = '1.200€ – 2.000€';

const photographers = [
  {
    name: 'Carmen Vidal',
    city: 'Zaragoza',
    zone: 'Zaragoza · Huesca · La Rioja',
    style: 'Documental y romántico',
    styleDesc: 'Momentos auténticos con luz natural y paleta cálida',
    price: 'desde 1.400€',
    bio: 'Carmen Vidal lleva más de 8 años fotografiando bodas en Aragón. Su trabajo mezcla la narrativa documental con composiciones románticas que aprovechan la arquitectura mudéjar y los paisajes del Ebro. Discreta durante la ceremonia, cercana con las parejas.',
    avatar: '/images/cities/zaragoza.jpg',
    portfolio: [
      { src: '/images/portfolio/malaga-2.jpg', alt: 'Boda en Zaragoza — Carmen Vidal' },
      { src: '/images/portfolio/malaga-4.jpg', alt: 'Bodas Aragón — Carmen Vidal' },
      { src: '/images/cities/zaragoza.jpg',    alt: 'Fotografía de boda Zaragoza — Carmen Vidal' },
    ],
    badge: 'Verificado',
    yearsExp: 8,
    awards: ['Top 50 Wedding Photographers Spain 2024'],
    photoCredit: 'Carmen Vidal',
  },
];

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Mejores fotógrafos de bodas en ${city}`,
  "description": `Directorio de los mejores fotógrafos de bodas en ${city} y Aragón.`,
  "url": `https://${site.domain}/${slug}/`,
  "numberOfItems": photographers.length,
  "itemListElement": photographers.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "LocalBusiness",
      "name": p.name,
      "description": p.bio,
      "areaServed": { "@type": "City", "name": city },
      "priceRange": p.price,
      "knowsAbout": "Fotografía de bodas",
    }
  })),
};
---

<BaseLayout
  title="Fotógrafos de Bodas en Zaragoza — Directorio verificado 2026"
  description="Los mejores fotógrafos de bodas en Zaragoza y Aragón. Perfiles verificados, portfolios reales y consulta de disponibilidad directa. Precio medio: 1.200€ – 2.000€."
  canonical={`https://${site.domain}/${slug}/`}
  schema={schemaOrg}
>
  <SiteHeader transparent={true} />
  <main>
    <Hero
      city={city}
      h1={`Fotógrafos de Bodas\nen Zaragoza`}
      subtitle="Fotógrafos verificados en Zaragoza y toda la provincia de Aragón. Contacta directamente, sin intermediarios."
      ctaText="Ver fotógrafos"
      ctaHref="#fotografos"
      imageSrc="/images/cities/zaragoza.jpg"
    />

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="section-eyebrow mb-4">Zaragoza y Aragón</p>
            <h2 class="section-title mb-6">Mudéjar, Ebro<br/>y bodas únicas</h2>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed mb-4">
              Zaragoza tiene un carácter propio que los mejores fotógrafos saben leer. La Basílica del Pilar, las fincas del Moncayo o los masicos aragoneses crean fondos imposibles de replicar en otro lugar.
            </p>
            <p class="font-['Lato'] text-[#6B5E58] leading-relaxed">
              La luz del interior peninsular en verano es especialmente demandante. Los fotógrafos de aquí la conocen bien y saben cómo trabajar con ella para conseguir imágenes cálidas y naturales sin las sombras duras del mediodía.
            </p>
          </div>
          <div class="bg-[#F2E8D5] rounded-sm p-8">
            <p class="section-eyebrow mb-6">Datos de interés</p>
            <ul class="space-y-4">
              {[
                { label: 'Precio medio', value: avgPrice },
                { label: 'Fotógrafos verificados', value: `${photographers.length} activo` },
                { label: 'Temporada alta', value: 'Mayo – Septiembre' },
                { label: 'Zonas populares', value: 'Pilar, Moncayo, Teruel, Huesca' },
              ].map(item => (
                <li class="flex items-start justify-between gap-4">
                  <span class="font-['Lato'] text-xs font-bold uppercase tracking-widest text-[#6B5E58]">{item.label}</span>
                  <span class="font-['Cormorant_Garamond'] text-lg font-semibold text-[#1C1814] text-right">{item.value}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section id="fotografos" class="py-20 bg-[#FAF7F2]">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-14">
          <p class="section-eyebrow mb-4">Directorio exclusivo</p>
          <h2 class="section-title">Fotógrafo de boda<br/>de referencia en Zaragoza</h2>
          <span class="gold-divider"></span>
          <p class="font-['Lato'] text-[#6B5E58] max-w-lg mx-auto mt-4 text-sm leading-relaxed">
            Solo listamos 2 fotógrafos por ciudad. Ambos pasan nuestra revisión de portfolio.
          </p>
        </div>

        <div class="space-y-8">
          {photographers.map((p, i) => <PhotographerProfile photographer={p} featured={i === 0} />)}
        </div>

        <!-- Plaza disponible -->
        <div class="mt-8 border-2 border-dashed border-[#E8DDD3] rounded-sm p-10 text-center">
          <p class="font-['Cormorant_Garamond'] text-2xl font-semibold text-[#6B5E58] mb-3">Plaza disponible en Zaragoza</p>
          <p class="font-['Lato'] text-sm text-[#9A8880] max-w-sm mx-auto mb-6 leading-relaxed">
            Estamos seleccionando un segundo fotógrafo para cubrir toda la provincia. ¿Eres fotógrafo de bodas en Aragón?
          </p>
          <a href="/unete/" class="btn-outline text-sm px-6 py-3">Solicitar plaza →</a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-6">
          ¿Cuánto cuesta un fotógrafo de bodas en Zaragoza?
        </h2>
        <div class="font-['Lato'] text-[#6B5E58] text-sm leading-loose space-y-4">
          <p>
            En Zaragoza, el precio medio de un fotógrafo de bodas en 2026 está entre <strong class="text-[#1C1814]">1.200€ y 2.000€</strong>. Las bodas en la capital tienen precios similares a otras ciudades medias españolas, con cierta variación según si la celebración es en finca rural o en venue urbano.
          </p>
          <p>
            Los paquetes estándar incluyen cobertura del día completo (8-12 horas), edición de 400-700 fotos y galería privada online. La sesión preboda y el segundo fotógrafo son los extras más habituales.
          </p>
          <p>
            Si vuestra boda es en verano, reservad con al menos 10-12 meses de antelación. Los meses de julio y agosto se completan especialmente rápido.
          </p>
        </div>
      </div>
    </section>

    <FAQSection city={city} />

    <section class="py-16 bg-[#F2E8D5]">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <p class="section-eyebrow mb-4">Más ciudades</p>
        <h2 class="font-['Cormorant_Garamond'] text-3xl font-semibold text-[#1C1814] mb-8">También buscamos en</h2>
        <div class="flex flex-wrap justify-center gap-3">
          {[
            { name: 'Madrid', slug: 'madrid' },
            { name: 'Bilbao', slug: 'bilbao' },
            { name: 'San Sebastián', slug: 'san-sebastian' },
          ].map(c => (
            <a href={`/${c.slug}/`} class="btn-outline text-sm px-6 py-2.5">
              Fotógrafos en {c.name}
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
  <WhatsAppFloat city={city} />
</BaseLayout>
